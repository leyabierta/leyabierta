{
	"name": "leyabierta",
	"type": "module",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"check": "biome check .",
		"format": "biome check --write .",
		"test": "bun test",
		"pipeline": "bun run packages/pipeline/src/cli.ts",
		"ingest": "bun run packages/pipeline/src/ingest-cli.ts",
		"ingest-analisis": "bun run packages/pipeline/src/ingest-analisis-cli.ts",
		"api": "bun run packages/api/src/index.ts",
		"api:dev": "bun --watch run packages/api/src/index.ts",
		"web": "bun run --cwd packages/web astro dev --port 4321",
		"dev": "bun run --cwd packages/web astro dev --port 4321",
		"generate-citizen-tags": "bun run packages/pipeline/src/scripts/generate-citizen-tags.ts",
		"generate-og": "bun run packages/api/src/scripts/generate-og-images.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@types/bun": "1.3.11",
		"@types/markdown-it": "^14.1.2",
		"@typescript/native-preview": "^7.0.0-dev.20260406.1",
		"markdown-it": "^14.1.1",
		"typescript": "5.9.3"
	},
	"dependencies": {
		"fast-xml-parser": "5.5.9"
	}
}
