---
interface Props {
	title: string;
	description?: string;
	ogTitle?: string;
	ogDescription?: string;
	ogType?: string;
	ogImage?: string;
	canonicalUrl?: string;
}

const SITE_URL = "https://leylibre.es";

const {
	title,
	description = "Legislacion espanola consolidada, accesible para todos.",
	ogTitle,
	ogDescription,
	ogType = "website",
	ogImage,
	canonicalUrl,
} = Astro.props;

const fullTitle = `${title} — Ley Libre`;
const resolvedOgTitle = ogTitle ?? fullTitle;
const resolvedOgDescription = ogDescription ?? description;
const resolvedOgImage = ogImage ?? `${SITE_URL}/logo.png`;
const resolvedCanonicalUrl = canonicalUrl ? `${SITE_URL}${canonicalUrl}` : undefined;
---

<!doctype html>
<html lang="es">
<script is:inline>
	(function () {
		var stored = localStorage.getItem("theme");
		if (stored === "light" || stored === "dark") {
			document.documentElement.setAttribute("data-theme", stored);
		}
	})();
</script>
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<meta name="description" content={description} />
	{resolvedCanonicalUrl && <link rel="canonical" href={resolvedCanonicalUrl} />}
	<link rel="icon" type="image/x-icon" href="/favicon.ico" />
	<link rel="alternate" type="application/rss+xml" title="Ley Libre — RSS" href="/feed.xml" />
	<title>{fullTitle}</title>

	<!-- Open Graph -->
	<meta property="og:title" content={resolvedOgTitle} />
	<meta property="og:description" content={resolvedOgDescription} />
	<meta property="og:type" content={ogType} />
	<meta property="og:site_name" content="Ley Libre" />
	<meta property="og:image" content={resolvedOgImage} />
	{resolvedCanonicalUrl && <meta property="og:url" content={resolvedCanonicalUrl} />}

	<!-- Twitter Card -->
	<meta name="twitter:card" content="summary" />
	<meta name="twitter:title" content={resolvedOgTitle} />
	<meta name="twitter:description" content={resolvedOgDescription} />
	<meta name="twitter:image" content={resolvedOgImage} />
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
	<style is:global>
		:root {
			--bg: #f7f4ef;
			--surface: #ffffff;
			--text: #0b1120;
			--text-secondary: #4a6078;
			--text-muted: #6b8299;
			--border: #c4ced8;
			--border-light: #e8ecf0;
			--accent: #1a3f7a;
			--accent-light: #2b5ea7;
			--accent-bg: #e6eef8;
			--accent-faint: #f2f6fb;
			--success: #1a7a4e;
			--success-bg: #e3f4ec;
			--warning: #b8860b;
			--warning-bg: #fdf5e0;
			--danger: #b91c1c;
			--danger-bg: #fde8e8;
			--tierra-warm: #efe9de;
			--tierra-deep: #d9cdb8;
			--max-w: 52rem;
			--font-serif: "Source Serif 4", Georgia, serif;
			--font-sans: "Inter", system-ui, sans-serif;
			--font-mono: "JetBrains Mono", monospace;
		}

		@media (prefers-color-scheme: dark) {
			:root:not([data-theme="light"]) {
				--bg: #0f1117;
				--surface: #1a1d27;
				--text: #e8eaf0;
				--text-secondary: #a0aab8;
				--text-muted: #6b7a8d;
				--border: #2a3040;
				--border-light: #1f2530;
				--accent: #6ba3d6;
				--accent-light: #8bbce6;
				--accent-bg: #1a2a3d;
				--accent-faint: #141e2d;
				--tierra-warm: #141820;
				--tierra-deep: #1f2530;
				--success: #3db87a;
				--success-bg: #142a1e;
				--warning: #d4a017;
				--warning-bg: #2a2210;
				--danger: #e85454;
				--danger-bg: #2a1414;
			}
		}

		:root[data-theme="dark"] {
			--bg: #0f1117;
			--surface: #1a1d27;
			--text: #e8eaf0;
			--text-secondary: #a0aab8;
			--text-muted: #6b7a8d;
			--border: #2a3040;
			--border-light: #1f2530;
			--accent: #6ba3d6;
			--accent-light: #8bbce6;
			--accent-bg: #1a2a3d;
			--accent-faint: #141e2d;
			--tierra-warm: #141820;
			--tierra-deep: #1f2530;
			--success: #3db87a;
			--success-bg: #142a1e;
			--warning: #d4a017;
			--warning-bg: #2a2210;
			--danger: #e85454;
			--danger-bg: #2a1414;
		}

		*, *::before, *::after { box-sizing: border-box; margin: 0; }

		html {
			font-family: var(--font-sans);
			background: var(--bg);
			color: var(--text);
			line-height: 1.65;
			font-size: 16px;
			-webkit-font-smoothing: antialiased;
		}

		a { color: var(--accent-light); text-decoration: none; }
		a:hover { text-decoration: underline; }

		.container { max-width: var(--max-w); margin: 0 auto; padding: 0 1.25rem; }

		/* ── Header ── */
		header {
			border-bottom: 1px solid var(--border);
			background: rgba(247,244,239,0.88);
			backdrop-filter: blur(16px);
			position: sticky;
			top: 0;
			z-index: 100;
		}
		@media (prefers-color-scheme: dark) {
			:root:not([data-theme="light"]) header {
				background: rgba(15,17,23,0.88);
			}
		}
		:root[data-theme="dark"] header {
			background: rgba(15,17,23,0.88);
		}
		:root[data-theme="light"] header {
			background: rgba(247,244,239,0.88);
		}
		/* ── Theme toggle dropdown ── */
		.theme-wrap { position: relative; }
		.theme-toggle {
			background: none;
			border: 1px solid var(--border);
			border-radius: 4px;
			color: var(--text-muted);
			cursor: pointer;
			font-size: 0.875rem;
			line-height: 1;
			padding: 0.25rem 0.4rem;
			transition: color 0.15s, border-color 0.15s;
		}
		.theme-toggle:hover {
			color: var(--accent);
			border-color: var(--accent);
		}
		.theme-menu {
			display: none;
			position: absolute;
			right: 0;
			top: calc(100% + 0.375rem);
			background: var(--surface);
			border: 1px solid var(--border);
			border-radius: 8px;
			padding: 0.375rem;
			min-width: 9rem;
			box-shadow: 0 4px 16px rgba(11,17,32,0.12);
			z-index: 200;
		}
		.theme-menu.open { display: block; }
		.theme-option {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			width: 100%;
			padding: 0.4rem 0.625rem;
			border: none;
			background: none;
			color: var(--text-secondary);
			font-size: 0.8125rem;
			font-family: var(--font-sans);
			border-radius: 4px;
			cursor: pointer;
			white-space: nowrap;
		}
		.theme-option:hover { background: var(--accent-bg); color: var(--accent); }
		.theme-option.active { color: var(--accent); font-weight: 600; }
		header nav {
			max-width: var(--max-w);
			margin: 0 auto;
			padding: 0.875rem 1.25rem;
			display: flex;
			align-items: center;
			gap: 1.75rem;
		}
		.logo {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			font-family: var(--font-serif);
			font-size: 1.125rem;
			font-weight: 700;
			color: var(--text);
			letter-spacing: -0.01em;
		}
		.logo:hover { text-decoration: none; color: var(--text); }
		.logo img { width: 28px; height: 28px; border-radius: 4px; }
		.logo span { color: var(--accent); }
		.nav-links {
			display: flex;
			gap: 1.25rem;
			align-items: center;
			margin-left: auto;
		}
		header nav a:not(.logo) {
			display: inline-flex;
			align-items: center;
			gap: 0.3rem;
			font-size: 0.8125rem;
			color: var(--text-muted);
			font-weight: 500;
			letter-spacing: 0.03em;
		}
		header nav a:not(.logo):hover { color: var(--accent); text-decoration: none; }
		header nav a:not(.logo) svg { flex-shrink: 0; }

		/* ── Footer ── */
		footer {
			border-top: 1px solid var(--tierra-deep);
			background: var(--tierra-warm);
			padding: 2.5rem 0 2rem;
			margin-top: 4rem;
			font-size: 0.8125rem;
			color: var(--text-muted);
			line-height: 1.8;
		}
		footer a { color: var(--text-muted); text-decoration: underline; }
		.footer-grid {
			display: flex;
			justify-content: space-between;
			gap: 2rem;
		}
		.footer-grid p { margin: 0; }
		.footer-right { text-align: right; }
		.footer-tagline {
			margin-top: 1.5rem;
			padding-top: 1rem;
			border-top: 1px solid var(--tierra-deep);
			text-align: center;
			font-family: var(--font-serif);
			font-style: italic;
			font-size: 0.8125rem;
			color: var(--text-muted);
		}
		@media (max-width: 640px) {
			.footer-grid { flex-direction: column; gap: 1rem; }
			.footer-right { text-align: left; }
		}

		/* ── Badges ── */
		.badge {
			display: inline-flex;
			align-items: center;
			gap: 0.3rem;
			padding: 0.2rem 0.55rem;
			border-radius: 4px;
			font-size: 0.6875rem;
			font-weight: 600;
			text-transform: capitalize;
			letter-spacing: 0.01em;
		}
		.badge-vigente { background: var(--success-bg); color: var(--success); }
		.badge-derogada { background: var(--danger-bg); color: var(--danger); }
		.badge-parcialmente_derogada { background: var(--warning-bg); color: var(--warning); }

		/* ── Buttons ── */
		.btn {
			display: inline-flex;
			align-items: center;
			gap: 0.4rem;
			padding: 0.5rem 1.125rem;
			font-size: 0.875rem;
			font-weight: 600;
			border-radius: 6px;
			border: 1.5px solid var(--border);
			background: var(--surface);
			color: var(--text-secondary);
			cursor: pointer;
			transition: all 0.15s;
		}
		.btn:hover { border-color: var(--accent); color: var(--accent); text-decoration: none; }
		.btn-primary {
			background: var(--accent);
			color: white;
			border-color: var(--accent);
		}
		.btn-primary:hover { background: var(--accent-light); border-color: var(--accent-light); color: white; }

		/* ── Pagination ── */
		.pagination {
			margin-top: 1.5rem;
			display: flex;
			justify-content: center;
			align-items: center;
			gap: 0.25rem;
			font-size: 0.8125rem;
		}
		.page-num {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			min-width: 2rem;
			height: 2rem;
			padding: 0 0.375rem;
			border-radius: 4px;
			color: var(--text-secondary);
			font-variant-numeric: tabular-nums;
		}
		.page-num:hover { background: var(--accent-bg); color: var(--accent); text-decoration: none; }
		.page-num.current { background: var(--accent); color: white; font-weight: 600; }
		.page-ellipsis { color: var(--text-muted); padding: 0 0.25rem; }

		/* ── Responsive ── */
		@media (max-width: 640px) {
			.container { padding: 0 1rem; }
			header nav { padding: 0.75rem 1rem; gap: 1rem; }
			.nav-hide-mobile { display: none; }
		}
	</style>
</head>
<body>
	<header>
		<nav>
			<a href="/" class="logo">
				<img src="/logo.png" alt="" width="28" height="28" />
				Ley <span>Libre</span>
			</a>
			<div class="nav-links">
				<a href="/"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg> Buscar</a>
				<a href="/anomalias">Anomalias</a>
				<a href="/feed.xml" target="_blank" rel="noopener" class="nav-hide-mobile"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg> RSS</a>
				<a href="https://github.com/pinka/leylibre" target="_blank" rel="noopener" class="nav-hide-mobile"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg> GitHub</a>
				<div class="theme-wrap">
					<button id="theme-toggle" class="theme-toggle" type="button" aria-label="Cambiar tema"></button>
					<div class="theme-menu" id="theme-menu">
						<button class="theme-option" data-theme-value="light"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg> Claro</button>
						<button class="theme-option" data-theme-value="dark"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg> Oscuro</button>
						<button class="theme-option" data-theme-value="system"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg> Sistema</button>
					</div>
				</div>
			</div>
		</nav>
	</header>

	<main class="container" style="padding-top: 2rem; padding-bottom: 2rem;">
		<slot />
	</main>

	<footer>
		<div class="container">
			<div class="footer-grid">
				<div>
					<p>Fuente: <a href="https://www.boe.es" target="_blank" rel="noopener">Agencia Estatal Boletin Oficial del Estado</a></p>
					<p>Los textos legislativos son de dominio publico.</p>
				</div>
				<div class="footer-right">
					<p>Codigo fuente bajo <a href="https://github.com/pinka/leylibre" target="_blank" rel="noopener">licencia MIT</a></p>
					<p>Ley Libre es un proyecto de codigo abierto.</p>
				</div>
			</div>
			<div class="footer-tagline">La ley pertenece al pueblo.</div>
		</div>
	</footer>
	<script is:inline>
		(function () {
			var btn = document.getElementById("theme-toggle");
			var menu = document.getElementById("theme-menu");
			var options = menu.querySelectorAll(".theme-option");

			function getEffective(theme) {
				if (theme === "light" || theme === "dark") return theme;
				return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
			}

			function updateIcon(theme) {
				var effective = getEffective(theme);
				btn.innerHTML = effective === "dark"
					? '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>'
					: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>';
			}

			function updateActive(theme) {
				var val = theme || "system";
				options.forEach(function (o) {
					o.classList.toggle("active", o.getAttribute("data-theme-value") === val);
				});
			}

			function currentPref() {
				var stored = localStorage.getItem("theme");
				if (stored === "light" || stored === "dark") return stored;
				return null;
			}

			function apply(theme) {
				if (theme === "light" || theme === "dark") {
					document.documentElement.setAttribute("data-theme", theme);
					localStorage.setItem("theme", theme);
				} else {
					document.documentElement.removeAttribute("data-theme");
					localStorage.removeItem("theme");
				}
				updateIcon(theme);
				updateActive(theme);
			}

			btn.addEventListener("click", function (e) {
				e.stopPropagation();
				menu.classList.toggle("open");
			});

			options.forEach(function (o) {
				o.addEventListener("click", function (e) {
					e.stopPropagation();
					var val = o.getAttribute("data-theme-value");
					apply(val === "system" ? null : val);
					menu.classList.remove("open");
				});
			});

			document.addEventListener("click", function () {
				menu.classList.remove("open");
			});

			var pref = currentPref();
			updateIcon(pref);
			updateActive(pref);

			window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", function () {
				updateIcon(currentPref());
			});
		})();
	</script>
</body>
</html>
