---
import Base from "./Base.astro";

interface Props {
	title: string;
	description: string;
	canonicalUrl: string;
}

const { title, description, canonicalUrl } = Astro.props;
---

<Base title={title} description={description} canonicalUrl={canonicalUrl}>
	<style>
		.legal-page {
			max-width: 42rem;
		}
		.legal-page h1 {
			font-family: var(--font-serif);
			font-size: 1.75rem;
			font-weight: 700;
			margin-bottom: 0.25rem;
		}
		.legal-page h2 {
			font-family: var(--font-serif);
			font-size: 1.2rem;
			font-weight: 600;
			margin-top: 2.5rem;
			margin-bottom: 0.75rem;
			padding-bottom: 0.5rem;
			border-bottom: 1px solid var(--border-light);
		}
		.legal-page h3 {
			font-size: 1rem;
			font-weight: 600;
			margin-top: 2.25rem;
			margin-bottom: 0.625rem;
		}
		.legal-page p {
			font-size: 0.9375rem;
			color: var(--text-secondary);
			line-height: 1.8;
			margin-bottom: 0.875rem;
		}
		.legal-page li {
			font-size: 0.9375rem;
			color: var(--text-secondary);
			line-height: 1.8;
		}
		.legal-page ul {
			padding-left: 1.5rem;
			margin: 0.5rem 0 1rem;
		}
		.legal-page a {
			color: var(--accent);
		}
		.legal-updated {
			font-size: 0.8125rem;
			color: var(--text-muted);
			margin-bottom: 1rem;
		}
		.legal-table {
			width: 100%;
			border-collapse: collapse;
			margin: 1.25rem 0;
			font-size: 0.8125rem;
			line-height: 1.6;
		}
		.legal-table th,
		.legal-table td {
			border: 1px solid var(--border-light);
			padding: 0.75rem 1rem;
			text-align: left;
			vertical-align: top;
		}
		.legal-table th {
			background: var(--surface);
			font-weight: 600;
			color: var(--text);
			font-size: 0.8125rem;
			text-transform: uppercase;
			letter-spacing: 0.03em;
		}
		.legal-table td {
			color: var(--text-secondary);
		}
		.legal-table tr:nth-child(even) td {
			background: var(--bg);
		}
	</style>

	<div class="legal-page">
		<slot />
	</div>
</Base>
