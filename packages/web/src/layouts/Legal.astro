---
import Base from "./Base.astro";

interface Props {
	title: string;
	description: string;
	canonicalUrl: string;
}

const { title, description, canonicalUrl } = Astro.props;
---

<Base title={title} description={description} canonicalUrl={canonicalUrl}>
	<style>
		.legal-page {
			max-width: 42rem;
		}
		.legal-page h1 {
			font-family: var(--font-serif);
			font-size: 1.75rem;
			font-weight: 700;
			color: var(--text);
			margin: 0 0 0.25rem;
		}
		.legal-updated {
			font-size: 0.8125rem;
			color: var(--text-muted);
			margin: 0.25rem 0 0;
		}
	</style>

	<div class="legal-page prose">
		<slot />
	</div>
</Base>
