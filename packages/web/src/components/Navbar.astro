---
/**
 * Navbar global — V1 Institucional clásico (Claude Design, Wave 3 redesign)
 *
 * Layout:
 *   ┌─ Strip oscuro 28px ────────────────────────────────────────────────┐
 *   │ ARCHIVO LEGISLATIVO PÚBLICO · Fuente: BOE       API · RSS · ☾ Oscuro │
 *   ├─ Fila principal 64px ──────────────────────────────────────────────┤
 *   │ [Logo]   Leyes  Pregunta  Cambios  Datos  Sobre   🔍 Buscar leyes…  Suscribirme │
 *   └────────────────────────────────────────────────────────────────────┘
 *
 * Activo: underline 3px en accent + weight 600 (no sello sólido).
 * Mobile (<768px): logo + hamburger; menú expandido con items, buscador y CTA.
 */

const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
	if (href === "/") {
		return pathname === "/" || pathname.startsWith("/leyes");
	}
	return pathname.startsWith(href.replace(/\/$/, ""));
}

const NAV_LINKS = [
	{ label: "Leyes", href: "/" },
	{ label: "Pregunta", href: "/pregunta/" },
	{ label: "Cambios", href: "/cambios/" },
	{ label: "Datos", href: "/datos/" },
	{ label: "Sobre", href: "/sobre/" },
];
---

<header class="site-header">
	<!-- Strip institucional superior -->
	<div class="util-strip">
		<div class="util-inner">
			<span class="util-kicker">ARCHIVO LEGISLATIVO PÚBLICO · Fuente: BOE</span>
			<div class="util-right">
				<a href="/datos/" class="util-link">API</a>
				<span class="util-sep" aria-hidden="true">·</span>
				<a href="/feed.xml" class="util-link">RSS</a>
				<span class="util-sep" aria-hidden="true">·</span>
				<button
					id="theme-toggle"
					class="util-theme"
					type="button"
					aria-label="Cambiar tema"
				>
					<span class="theme-icon" aria-hidden="true"></span>
					<span class="theme-label">Oscuro</span>
				</button>
			</div>
		</div>
	</div>

	<!-- Fila principal -->
	<nav class="nav-row" aria-label="Principal">
		<a href="/" class="logo" aria-label="Ley Abierta — Inicio">
			<picture>
				<source srcset="/logo-full.webp" type="image/webp" />
				<img
					src="/logo-full.png"
					alt="Ley Abierta"
					width="258"
					height="40"
					fetchpriority="high"
				/>
			</picture>
		</a>

		<!-- Hamburguesa mobile -->
		<button
			id="menu-toggle"
			class="menu-toggle"
			type="button"
			aria-label="Abrir menú"
			aria-expanded="false"
			aria-controls="nav-collapse"
		>
			<svg class="menu-icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
				<line x1="3" y1="6" x2="21" y2="6"/>
				<line x1="3" y1="12" x2="21" y2="12"/>
				<line x1="3" y1="18" x2="21" y2="18"/>
			</svg>
			<svg class="menu-icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
				<line x1="18" y1="6" x2="6" y2="18"/>
				<line x1="6" y1="6" x2="18" y2="18"/>
			</svg>
		</button>

		<!-- Items + utilidades (colapsa en mobile) -->
		<div class="nav-collapse" id="nav-collapse">
			<ul class="nav-items" role="list">
				{NAV_LINKS.map((l) => (
					<li>
						<a
							href={l.href}
							aria-current={isActive(l.href) ? "page" : undefined}
							class:list={["nav-link", { "nav-active": isActive(l.href) }]}
						>
							{l.label}
						</a>
					</li>
				))}
			</ul>

			<form class="nav-search" action="/leyes/" method="get" role="search">
				<label for="nav-q" class="sr-only">Buscar leyes</label>
				<span class="nav-search-icon" aria-hidden="true">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="11" cy="11" r="8"/>
						<line x1="21" y1="21" x2="16.65" y2="16.65"/>
					</svg>
				</span>
				<input
					id="nav-q"
					name="q"
					type="search"
					placeholder="Buscar leyes…"
					autocomplete="off"
					class="nav-search-input"
				/>
			</form>

			<div class="nav-cta-row">
				<a href="/alertas/" class="nav-cta">Suscribirme</a>
				<button
					id="theme-toggle-mobile"
					class="theme-toggle-mobile"
					type="button"
					aria-label="Cambiar tema"
				>
					<span class="theme-icon-mobile" aria-hidden="true"></span>
				</button>
			</div>
		</div>
	</nav>
</header>

<style>
	/* ─────────── Strip institucional superior ─────────── */
	.util-strip {
		background: #0b1d3a;
		color: rgba(255, 255, 255, 0.78);
		font-size: 11px;
	}
	:root[data-theme="dark"] .util-strip {
		background: #0a1220;
	}
	.util-inner {
		max-width: 72rem;
		margin: 0 auto;
		padding: 0.4rem 1.25rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		min-height: 28px;
	}
	.util-kicker {
		font-family: var(--font-mono);
		font-size: 10.5px;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.7);
	}
	.util-right {
		display: flex;
		align-items: center;
		gap: 0.9rem;
	}
	.util-link {
		color: rgba(255, 255, 255, 0.7);
		font-size: 11px;
		text-decoration: none;
	}
	.util-link:hover {
		color: rgba(255, 255, 255, 0.95);
		text-decoration: none;
	}
	.util-sep {
		color: rgba(255, 255, 255, 0.25);
	}
	.util-theme {
		background: none;
		border: none;
		color: rgba(255, 255, 255, 0.7);
		cursor: pointer;
		padding: 0;
		display: inline-flex;
		align-items: center;
		gap: 5px;
		font-size: 11px;
		font-family: var(--font-sans);
	}
	.util-theme:hover {
		color: rgba(255, 255, 255, 0.95);
	}
	.theme-icon {
		display: inline-flex;
		width: 13px;
		height: 13px;
	}

	/* ─────────── Fila principal ─────────── */
	.site-header {
		border-bottom: 1px solid var(--border);
		background: var(--surface);
	}
	.nav-row {
		max-width: 72rem;
		margin: 0 auto;
		padding: 0 1.25rem;
		display: flex;
		align-items: stretch;
		gap: 2rem;
		height: 64px;
	}
	.logo {
		display: inline-flex;
		align-items: center;
		flex-shrink: 0;
		text-decoration: none;
	}
	.logo img {
		height: 28px;
		width: auto;
		display: block;
	}
	.logo:hover {
		text-decoration: none;
	}

	/* Items */
	.nav-collapse {
		display: flex;
		align-items: stretch;
		gap: 0;
		flex: 1;
		min-width: 0;
	}
	.nav-items {
		display: flex;
		align-items: stretch;
		gap: 0;
		list-style: none;
		padding: 0;
		margin: 0;
		height: 100%;
	}
	.nav-items li {
		display: flex;
	}
	.nav-link {
		display: inline-flex;
		align-items: center;
		padding: 0 0.875rem;
		font-size: 14px;
		font-weight: 500;
		color: var(--text-muted);
		text-decoration: none;
		border-bottom: 3px solid transparent;
		margin-bottom: -1px;
		letter-spacing: 0.005em;
		transition: color 0.12s ease-out;
	}
	.nav-link:hover {
		color: var(--text);
		text-decoration: none;
	}
	.nav-active {
		color: var(--accent);
		font-weight: 600;
		border-bottom-color: var(--accent);
	}
	:root[data-theme="dark"] .nav-active {
		color: var(--accent-light);
		border-bottom-color: var(--accent-light);
	}

	/* Buscador inline + CTA — empujados a la derecha */
	.nav-search {
		margin-left: auto;
		display: flex;
		align-items: center;
		flex-shrink: 0;
		position: relative;
	}
	.nav-search-icon {
		position: absolute;
		left: 10px;
		top: 50%;
		transform: translateY(-50%);
		color: var(--text-muted);
		pointer-events: none;
		display: inline-flex;
	}
	.nav-search-input {
		height: 34px;
		width: 200px;
		padding: 0 0.75rem 0 2rem;
		border: 1px solid var(--border);
		border-radius: 6px;
		background: var(--surface);
		color: var(--text);
		font-family: var(--font-sans);
		font-size: 13px;
		line-height: 1;
		outline: none;
		transition: border-color 0.12s, box-shadow 0.12s;
	}
	.nav-search-input::placeholder {
		color: var(--text-muted);
	}
	.nav-search-input:focus {
		border-color: var(--accent);
		box-shadow: 0 0 0 3px var(--accent-faint);
	}
	.nav-cta-row {
		display: inline-flex;
		align-items: center;
		gap: 0.625rem;
		margin-left: 0.625rem;
	}
	.nav-cta {
		display: inline-flex;
		align-items: center;
		padding: 0.4rem 0.9rem;
		font-size: 13px;
		font-weight: 600;
		font-family: var(--font-sans);
		border-radius: 6px;
		border: 1.5px solid var(--border);
		background: var(--surface);
		color: var(--text-secondary);
		text-decoration: none;
		white-space: nowrap;
		transition: border-color 0.12s, color 0.12s;
	}
	.nav-cta:hover {
		border-color: var(--accent);
		color: var(--accent);
		text-decoration: none;
	}
	/* Theme toggle mobile — solo visible en mobile (strip se oculta) */
	.theme-toggle-mobile {
		display: none;
		background: none;
		border: 1px solid var(--border);
		border-radius: 8px;
		color: var(--text-muted);
		cursor: pointer;
		width: 44px;
		height: 44px;
		padding: 0;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}
	.theme-toggle-mobile:hover {
		color: var(--accent);
		border-color: var(--accent);
	}
	.theme-icon-mobile {
		display: inline-flex;
		width: 16px;
		height: 16px;
	}

	/* Hamburguesa — solo mobile */
	.menu-toggle {
		display: none;
		align-items: center;
		justify-content: center;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 6px;
		color: var(--text-secondary);
		cursor: pointer;
		width: 40px;
		height: 40px;
		padding: 0;
		margin-left: auto;
	}
	.menu-toggle:hover {
		color: var(--accent);
		border-color: var(--accent);
	}
	.menu-icon-close { display: none; }
	.menu-toggle[aria-expanded="true"] .menu-icon-open { display: none; }
	.menu-toggle[aria-expanded="true"] .menu-icon-close { display: block; }

	/* ─────────── Mobile (<768px) ─────────── */
	@media (max-width: 767px) {
		.util-strip { display: none; }
		.nav-row {
			height: auto;
			min-height: 56px;
			padding: 0.6rem 1rem;
			gap: 0.5rem;
			flex-wrap: wrap;
		}
		.logo img { height: 24px; }
		.menu-toggle { display: inline-flex; }

		.nav-collapse {
			display: none;
			flex-basis: 100%;
			flex-direction: column;
			align-items: stretch;
			gap: 0.125rem;
			padding: 0.5rem 0 0.5rem;
			border-top: 1px solid var(--border);
			margin-top: 0.6rem;
		}
		.nav-collapse.open { display: flex; }

		.nav-items {
			flex-direction: column;
			height: auto;
			gap: 0.125rem;
		}
		.nav-items li { width: 100%; }
		.nav-link {
			padding: 0.7rem 0.75rem;
			font-size: 15px;
			color: var(--text);
			border-bottom: none;
			margin-bottom: 0;
			border-radius: 8px;
			min-height: 2.75rem;
			width: 100%;
		}
		.nav-active {
			color: var(--accent);
			background: var(--accent-bg);
			border-bottom: none;
		}

		.nav-search {
			margin: 0.625rem 0 0;
			width: 100%;
		}
		.nav-search-input {
			width: 100%;
			height: 40px;
			font-size: 14px;
			padding-left: 2.25rem;
			border-radius: 8px;
		}
		.nav-search-icon { left: 12px; }

		.nav-cta-row {
			margin: 0.75rem 0 0;
			padding-top: 0.75rem;
			border-top: 1px solid var(--border-light);
			gap: 0.625rem;
			align-self: stretch;
		}
		.nav-cta {
			flex: 1;
			justify-content: center;
			border-radius: 8px;
			background: var(--surface);
			padding: 0.625rem 1rem;
			font-size: 14px;
			min-height: 2.75rem;
		}
		.theme-toggle-mobile { display: inline-flex; }
	}

	/* SR-only para labels accesibles */
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>

<script>
	// ─── Hamburguesa mobile ──────────────────────────────────
	var menuBtn = document.getElementById("menu-toggle");
	var navCollapse = document.getElementById("nav-collapse");
	if (menuBtn && navCollapse) {
		menuBtn.addEventListener("click", function () {
			var isOpen = navCollapse.classList.toggle("open");
			menuBtn.setAttribute("aria-expanded", isOpen ? "true" : "false");
			menuBtn.setAttribute("aria-label", isOpen ? "Cerrar menú" : "Abrir menú");
		});
		// Cerrar al click fuera
		document.addEventListener("click", function (e) {
			var target = e.target as Node;
			if (!menuBtn.contains(target) && !navCollapse.contains(target)) {
				navCollapse.classList.remove("open");
				menuBtn.setAttribute("aria-expanded", "false");
				menuBtn.setAttribute("aria-label", "Abrir menú");
			}
		});
		// Escape cierra y devuelve foco al toggle
		document.addEventListener("keydown", function (e) {
			if (e.key === "Escape" && navCollapse.classList.contains("open")) {
				navCollapse.classList.remove("open");
				menuBtn.setAttribute("aria-expanded", "false");
				menuBtn.setAttribute("aria-label", "Abrir menú");
				menuBtn.focus();
			}
		});
	}

	// ─── Theme toggle (strip oscuro + botón mobile) ──────────
	var themeBtnStrip = document.getElementById("theme-toggle");
	var themeBtnMobile = document.getElementById("theme-toggle-mobile");
	var sunSvgStrip =
		'<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>';
	var moonSvgStrip =
		'<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
	var sunSvgMobile = sunSvgStrip.replace(/width="13" height="13"/, 'width="16" height="16"');
	var moonSvgMobile = moonSvgStrip.replace(/width="13" height="13"/, 'width="16" height="16"');

	function isDark() {
		return document.documentElement.getAttribute("data-theme") === "dark";
	}
	function refreshTheme() {
		if (themeBtnStrip) {
			var iconSlot = themeBtnStrip.querySelector(".theme-icon");
			var labelSlot = themeBtnStrip.querySelector(".theme-label");
			if (iconSlot) iconSlot.innerHTML = isDark() ? sunSvgStrip : moonSvgStrip;
			if (labelSlot) labelSlot.textContent = isDark() ? "Claro" : "Oscuro";
		}
		if (themeBtnMobile) {
			var iconMobile = themeBtnMobile.querySelector(".theme-icon-mobile");
			if (iconMobile) iconMobile.innerHTML = isDark() ? sunSvgMobile : moonSvgMobile;
		}
	}
	refreshTheme();
	function onThemeClick() {
		var nextDark = !isDark();
		document.documentElement.setAttribute("data-theme", nextDark ? "dark" : "light");
		try {
			localStorage.setItem("theme", nextDark ? "dark" : "light");
		} catch (_) { /* localStorage may be blocked */ }
		refreshTheme();
	}
	if (themeBtnStrip) themeBtnStrip.addEventListener("click", onThemeClick);
	if (themeBtnMobile) themeBtnMobile.addEventListener("click", onThemeClick);
</script>
