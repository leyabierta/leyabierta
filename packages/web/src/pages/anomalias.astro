---
import Base from "../layouts/Base.astro";
import { getAnomalies } from "../lib/api";

const data = await getAnomalies();

const totalIssues =
	data.futureDates.length +
	data.emptyBlocks.length +
	data.unresolvedMaterias.length +
	data.missingEli.length;
---

<Base
	title="Anomalias detectadas"
	description="Errores y anomalias encontradas en los datos del BOE. Informacion util para mejorar la calidad de los datos oficiales."
	canonicalUrl="/anomalias"
>
	<style>
		.anomaly-intro {
			margin-bottom: 2rem;
		}
		.anomaly-intro h1 {
			font-family: var(--font-serif);
			font-size: 1.5rem;
			font-weight: 700;
			margin-bottom: 0.5rem;
		}
		.anomaly-intro p {
			font-size: 0.875rem;
			color: var(--text-secondary);
			line-height: 1.7;
		}

		.anomaly-summary {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
			gap: 0.75rem;
			margin-bottom: 2rem;
		}
		.summary-card {
			padding: 1rem;
			background: var(--surface);
			border: 1px solid var(--border-light);
			border-radius: 8px;
			text-align: center;
		}
		.summary-card .count {
			font-size: 1.5rem;
			font-weight: 700;
			color: var(--accent);
		}
		.summary-card .label {
			font-size: 0.6875rem;
			color: var(--text-muted);
			text-transform: uppercase;
			letter-spacing: 0.04em;
			margin-top: 0.125rem;
		}

		.anomaly-section {
			margin-bottom: 2.5rem;
		}
		.anomaly-section h2 {
			font-size: 1.125rem;
			font-weight: 600;
			margin-bottom: 0.25rem;
		}
		.anomaly-section .desc {
			font-size: 0.8125rem;
			color: var(--text-muted);
			margin-bottom: 1rem;
		}

		.anomaly-table {
			width: 100%;
			border-collapse: collapse;
			font-size: 0.8125rem;
		}
		.anomaly-table th {
			text-align: left;
			padding: 0.5rem 0.75rem;
			border-bottom: 2px solid var(--border);
			font-weight: 600;
			color: var(--text-secondary);
			font-size: 0.75rem;
			text-transform: uppercase;
			letter-spacing: 0.04em;
		}
		.anomaly-table td {
			padding: 0.5rem 0.75rem;
			border-bottom: 1px solid var(--border-light);
			color: var(--text-secondary);
		}
		.anomaly-table tr:last-child td { border-bottom: none; }
		.anomaly-table a { font-family: var(--font-mono); font-size: 0.75rem; }
		.anomaly-table .title-cell {
			max-width: 300px;
			overflow: hidden;
			text-overflow: ellipsis;
			white-space: nowrap;
		}
		.date-bad {
			color: var(--danger);
			font-weight: 600;
			font-family: var(--font-mono);
			font-size: 0.75rem;
		}
		.empty-state {
			padding: 2rem;
			text-align: center;
			color: var(--text-muted);
			font-size: 0.875rem;
		}

		@media (max-width: 640px) {
			.anomaly-table { font-size: 0.75rem; }
			.anomaly-table th, .anomaly-table td { padding: 0.375rem 0.5rem; }
			.title-cell { max-width: 150px; }
		}
	</style>

	<div class="anomaly-intro">
		<h1>Anomalias en datos del BOE</h1>
		<p>
			Ley Libre es un espejo fiel de los datos del BOE. Estas anomalias son errores o inconsistencias
			detectadas automaticamente en los datos oficiales. No las corregimos — las documentamos para
			ayudar a mejorar la calidad de los datos publicos.
		</p>
	</div>

	<div class="anomaly-summary">
		<div class="summary-card">
			<div class="count">{totalIssues}</div>
			<div class="label">Total anomalias</div>
		</div>
		<div class="summary-card">
			<div class="count">{data.futureDates.length}</div>
			<div class="label">Fechas imposibles</div>
		</div>
		<div class="summary-card">
			<div class="count">{data.emptyBlocks.length}</div>
			<div class="label">Articulos vacios</div>
		</div>
		<div class="summary-card">
			<div class="count">{data.unresolvedMaterias.length}</div>
			<div class="label">Materias sin resolver</div>
		</div>
		<div class="summary-card">
			<div class="count">{data.missingEli.length}</div>
			<div class="label">Sin URL ELI</div>
		</div>
	</div>

	{data.futureDates.length > 0 && (
		<div class="anomaly-section">
			<h2>Fechas imposibles</h2>
			<p class="desc">Reformas con fecha de publicacion posterior al ano 2100 o normas con fecha anterior a 1800. Probables errores tipograficos en los datos del BOE.</p>
			<table class="anomaly-table">
				<thead><tr><th>Norma</th><th>Titulo</th><th>Fecha</th><th>Fuente</th></tr></thead>
				<tbody>
					{data.futureDates.map(d => (
						<tr>
							<td><a href={`/laws/${d.norm_id}`}>{d.norm_id}</a></td>
							<td class="title-cell">{d.title}</td>
							<td><span class="date-bad">{d.date}</span></td>
							<td>{d.source_id && <a href={`https://www.boe.es/buscar/act.php?id=${d.source_id}`} target="_blank" rel="noopener">{d.source_id}</a>}</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	)}

	{data.emptyBlocks.length > 0 && (
		<div class="anomaly-section">
			<h2>Articulos con texto vacio</h2>
			<p class="desc">Bloques de tipo "precepto" (articulos) que no tienen contenido de texto. Pueden ser articulos derogados o errores en el XML del BOE.</p>
			<table class="anomaly-table">
				<thead><tr><th>Norma</th><th>Titulo</th><th>Bloque</th><th>Tipo</th></tr></thead>
				<tbody>
					{data.emptyBlocks.map(d => (
						<tr>
							<td><a href={`/laws/${d.norm_id}`}>{d.norm_id}</a></td>
							<td class="title-cell">{d.title}</td>
							<td><code>{d.block_id}</code></td>
							<td>{d.block_type}</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	)}

	{data.unresolvedMaterias.length > 0 && (
		<div class="anomaly-section">
			<h2>Materias sin resolver</h2>
			<p class="desc">Codigos de materia que aparecen en los meta tags ELI del BOE pero no estan en su API de datos auxiliares. El BOE usa estos codigos pero no los expone en su catalogo publico.</p>
			<table class="anomaly-table">
				<thead><tr><th>Norma</th><th>Titulo</th><th>Codigo</th></tr></thead>
				<tbody>
					{data.unresolvedMaterias.map(d => (
						<tr>
							<td><a href={`/laws/${d.norm_id}`}>{d.norm_id}</a></td>
							<td class="title-cell">{d.title}</td>
							<td><code>{d.materia}</code></td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	)}

	{data.missingEli.length > 0 && (
		<div class="anomaly-section">
			<h2>Normas sin URL ELI</h2>
			<p class="desc">Normas consolidadas que no tienen identificador ELI (European Legislation Identifier). Son principalmente normas publicadas en boletines autonomicos. La jurisdiccion se infiere del prefijo del identificador.</p>
			<details>
				<summary style="cursor: pointer; font-size: 0.8125rem; color: var(--accent); margin-bottom: 0.75rem;">
					Mostrar {data.missingEli.length} normas
				</summary>
				<table class="anomaly-table">
					<thead><tr><th>ID</th><th>Titulo</th><th>URL fuente</th></tr></thead>
					<tbody>
						{data.missingEli.map(d => (
							<tr>
								<td><a href={`/laws/${d.id ?? d.norm_id}`}>{d.id ?? d.norm_id}</a></td>
								<td class="title-cell">{d.title}</td>
								<td><a href={d.source_url} target="_blank" rel="noopener" style="font-size: 0.6875rem;">{d.source_url?.replace('https://www.boe.es/', '')}</a></td>
							</tr>
						))}
					</tbody>
				</table>
			</details>
		</div>
	)}

	{totalIssues === 0 && (
		<div class="empty-state">No se han detectado anomalias en los datos.</div>
	)}
</Base>
