---
import Base from "../layouts/Base.astro";
import { getAnomalies } from "../lib/api";

const data = await getAnomalies();

const totalIssues =
	data.futureDates.length +
	data.emptyBlocks.length +
	data.unresolvedMaterias.length +
	data.missingEli.length;
---

<Base
	title="Anomalias detectadas"
	description="Errores y anomalias encontradas en los datos del BOE. Informacion util para mejorar la calidad de los datos oficiales."
	canonicalUrl="/anomalias"
>
	<style>
		.anomaly-intro {
			margin-bottom: 2rem;
		}
		.anomaly-intro h1 {
			font-family: var(--font-serif);
			font-size: 1.5rem;
			font-weight: 700;
			margin-bottom: 0.5rem;
		}
		.anomaly-intro p {
			font-size: 0.875rem;
			color: var(--text-secondary);
			line-height: 1.7;
		}

		.anomaly-summary {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
			gap: 0.75rem;
			margin-bottom: 2rem;
		}
		.summary-card {
			padding: 1rem;
			background: var(--surface);
			border: 1px solid var(--border-light);
			border-radius: 8px;
			text-align: center;
		}
		.summary-card .count {
			font-size: 1.5rem;
			font-weight: 700;
			color: var(--accent);
		}
		.summary-card .label {
			font-size: 0.6875rem;
			color: var(--text-muted);
			text-transform: uppercase;
			letter-spacing: 0.04em;
			margin-top: 0.125rem;
		}

		.anomaly-section {
			margin-bottom: 2.5rem;
		}
		.anomaly-section h2 {
			font-size: 1.125rem;
			font-weight: 600;
			margin-bottom: 0.25rem;
		}
		.anomaly-section .desc {
			font-size: 0.8125rem;
			color: var(--text-muted);
			margin-bottom: 1rem;
		}

		.anomaly-table {
			width: 100%;
			border-collapse: collapse;
			font-size: 0.8125rem;
		}
		.anomaly-table th {
			text-align: left;
			padding: 0.5rem 0.75rem;
			border-bottom: 2px solid var(--border);
			font-weight: 600;
			color: var(--text-secondary);
			font-size: 0.75rem;
			text-transform: uppercase;
			letter-spacing: 0.04em;
		}
		.anomaly-table td {
			padding: 0.5rem 0.75rem;
			border-bottom: 1px solid var(--border-light);
			color: var(--text-secondary);
		}
		.anomaly-table tr:last-child td { border-bottom: none; }
		.anomaly-table a { font-family: var(--font-mono); font-size: 0.75rem; }
		.anomaly-table .title-cell {
			max-width: 300px;
			overflow: hidden;
			text-overflow: ellipsis;
			white-space: nowrap;
		}
		.date-bad {
			color: var(--danger);
			font-weight: 600;
			font-family: var(--font-mono);
			font-size: 0.75rem;
		}
		.empty-state {
			padding: 2rem;
			text-align: center;
			color: var(--text-muted);
			font-size: 0.875rem;
		}

		@media (max-width: 640px) {
			.anomaly-table { font-size: 0.75rem; }
			.anomaly-table th, .anomaly-table td { padding: 0.375rem 0.5rem; }
			.title-cell { max-width: 150px; }
		}
	</style>

	<div class="anomaly-intro">
		<h1>Anomalias en datos del BOE</h1>
		<p>
			Ley Libre es un espejo fiel de los datos del BOE. Estas anomalias son errores o inconsistencias
			detectadas automaticamente en los datos oficiales. No las corregimos — las documentamos para
			ayudar a mejorar la calidad de los datos publicos.
		</p>
	</div>

	<div class="anomaly-summary">
		<div class="summary-card">
			<div class="count">{totalIssues}</div>
			<div class="label">Total anomalias</div>
		</div>
		<div class="summary-card">
			<div class="count">{data.futureDates.length}</div>
			<div class="label">Fechas erroneas</div>
		</div>
		<div class="summary-card">
			<div class="count">{data.emptyBlocks.length}</div>
			<div class="label">Articulos vacios</div>
		</div>
		<div class="summary-card">
			<div class="count">{data.unresolvedMaterias.length}</div>
			<div class="label">Categorias sin nombre</div>
		</div>
		<div class="summary-card">
			<div class="count">{data.missingEli.length}</div>
			<div class="label">Sin enlace europeo</div>
		</div>
	</div>

	{data.futureDates.length > 0 && (
		<div class="anomaly-section">
			<h2>Fechas imposibles</h2>
			<p class="desc">Leyes cuya fecha de modificacion es imposible (por ejemplo, ano 2929). Son errores tipograficos en la fuente oficial del BOE.</p>
			<table class="anomaly-table">
				<thead><tr><th>Ley</th><th>Nombre</th><th>Fecha erronea</th><th>Modificada por</th></tr></thead>
				<tbody>
					{data.futureDates.map(d => (
						<tr>
							<td><a href={`/laws/${d.norm_id}`}>{d.norm_id}</a></td>
							<td class="title-cell">{d.title}</td>
							<td><span class="date-bad">{d.date}</span></td>
							<td>{d.source_id && <a href={`https://www.boe.es/buscar/act.php?id=${d.source_id}`} target="_blank" rel="noopener">{d.source_id}</a>}</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	)}

	{data.emptyBlocks.length > 0 && (
		<div class="anomaly-section">
			<h2>Articulos sin contenido</h2>
			<p class="desc">Articulos dentro de leyes que no tienen texto. Normalmente son articulos que fueron eliminados por una reforma posterior, pero cuyo hueco sigue existiendo en la estructura de la ley.</p>
			<table class="anomaly-table">
				<thead><tr><th>Ley</th><th>Nombre</th><th>Articulo</th></tr></thead>
				<tbody>
					{data.emptyBlocks.map(d => (
						<tr>
							<td><a href={`/laws/${d.norm_id}`}>{d.norm_id}</a></td>
							<td class="title-cell">{d.title}</td>
							<td>{d.block_title || d.block_id}</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	)}

	{data.unresolvedMaterias.length > 0 && (
		<div class="anomaly-section">
			<h2>Categorias sin nombre</h2>
			<p class="desc">El BOE clasifica cada ley por temas (materias) usando codigos numericos. Estos codigos deberian tener un nombre asociado, pero {new Set(data.unresolvedMaterias.map(d => d.materia)).size} de ellos no aparecen en el catalogo publico del BOE. Afectan a {data.unresolvedMaterias.length} clasificaciones.</p>
			<table class="anomaly-table">
				<thead><tr><th>Ley</th><th>Nombre</th><th>Codigo sin nombre</th></tr></thead>
				<tbody>
					{data.unresolvedMaterias.map(d => (
						<tr>
							<td><a href={`/laws/${d.norm_id}`}>{d.norm_id}</a></td>
							<td class="title-cell">{d.title}</td>
							<td><code>{d.materia}</code></td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	)}

	{data.missingEli.length > 0 && (
		<div class="anomaly-section">
			<h2>Leyes sin enlace europeo (ELI)</h2>
			<p class="desc">La mayoria de las leyes tienen un enlace estandarizado europeo llamado ELI que permite identificarlas de forma unica. Estas {data.missingEli.length} leyes, publicadas en boletines de comunidades autonomas, no lo tienen. Funcionan correctamente, pero no siguen el estandar.</p>
			<details>
				<summary style="cursor: pointer; font-size: 0.8125rem; color: var(--accent); margin-bottom: 0.75rem;">
					Mostrar {data.missingEli.length} normas
				</summary>
				<table class="anomaly-table">
					<thead><tr><th>ID</th><th>Titulo</th><th>URL fuente</th></tr></thead>
					<tbody>
						{data.missingEli.map(d => (
							<tr>
								<td><a href={`/laws/${d.id ?? d.norm_id}`}>{d.id ?? d.norm_id}</a></td>
								<td class="title-cell">{d.title}</td>
								<td><a href={d.source_url} target="_blank" rel="noopener" style="font-size: 0.6875rem;">{d.source_url?.replace('https://www.boe.es/', '')}</a></td>
							</tr>
						))}
					</tbody>
				</table>
			</details>
		</div>
	)}

	{totalIssues === 0 && (
		<div class="empty-state">No se han detectado anomalias en los datos.</div>
	)}
</Base>
