---
import Base from "../layouts/Base.astro";
import {
	searchLaws, getRanks, getMaterias as getMateriasFilter,
	getStats, getMostReformed, getJurisdictions, getRecentReforms,
} from "../lib/api";

const q = Astro.url.searchParams.get("q") ?? "";
const rank = Astro.url.searchParams.get("rank") ?? "";
const status = Astro.url.searchParams.get("status") ?? "";
const materia = Astro.url.searchParams.get("materia") ?? "";
const page = Number(Astro.url.searchParams.get("page") ?? "1");
const limit = 20;
const offset = (page - 1) * limit;

const hasSearch = q || rank || status || materia || page > 1;

// Always fetch search results + filters
const params: Record<string, string> = { limit: String(limit), offset: String(offset) };
if (q) params.q = q;
if (rank) params.rank = rank;
if (status) params.status = status;
if (materia) params.materia = materia;

const [result, ranks, materiasList] = await Promise.all([
	searchLaws(params),
	getRanks(),
	getMateriasFilter(),
]);

// Only fetch landing page data when no search active
const [stats, mostReformed, jurisdictions, recentReforms] = hasSearch
	? [null, null, null, null]
	: await Promise.all([
		getStats(),
		getMostReformed(),
		getJurisdictions(),
		getRecentReforms(),
	]);

const totalPages = Math.ceil(result.total / limit);

const RANK_LABELS: Record<string, string> = {
	constitucion: "Constitución",
	ley_organica: "Ley Orgánica",
	ley: "Ley",
	real_decreto_ley: "Real Decreto-ley",
	real_decreto_legislativo: "RD Legislativo",
	real_decreto: "Real Decreto",
	orden: "Orden",
	resolucion: "Resolución",
	acuerdo_internacional: "Acuerdo Int.",
	circular: "Circular",
	instruccion: "Instrucción",
	decreto: "Decreto",
	reglamento: "Reglamento",
};

const JURISDICTION_LABELS: Record<string, string> = {
	"es": "Estatal",
	"es-an": "Andalucía",
	"es-ar": "Aragón",
	"es-as": "Asturias",
	"es-cb": "Cantabria",
	"es-cl": "Castilla y León",
	"es-cm": "Castilla-La Mancha",
	"es-cn": "Canarias",
	"es-ct": "Cataluña",
	"es-ex": "Extremadura",
	"es-ga": "Galicia",
	"es-ib": "Illes Balears",
	"es-mc": "Murcia",
	"es-md": "Madrid",
	"es-nc": "Navarra",
	"es-pv": "País Vasco",
	"es-ri": "La Rioja",
	"es-vc": "C. Valenciana",
};

function buildPageUrl(p: number): string {
	const u = new URLSearchParams();
	if (q) u.set("q", q);
	if (rank) u.set("rank", rank);
	if (status) u.set("status", status);
	if (materia) u.set("materia", materia);
	if (p > 1) u.set("page", String(p));
	const s = u.toString();
	return s ? `/?${s}` : "/";
}

function pageNumbers(current: number, total: number): (number | "...")[] {
	if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
	const pages: (number | "...")[] = [];
	const near = [current - 1, current, current + 1].filter(n => n >= 1 && n <= total);
	const all = new Set([1, 2, ...near, total - 1, total]);
	const sorted = [...all].sort((a, b) => a - b);
	for (let i = 0; i < sorted.length; i++) {
		if (i > 0 && sorted[i]! - sorted[i - 1]! > 1) pages.push("...");
		pages.push(sorted[i]!);
	}
	return pages;
}

function buildUrlWithout(excludeKey: string): string {
	const u = new URLSearchParams();
	if (q && excludeKey !== "q") u.set("q", q);
	if (rank && excludeKey !== "rank") u.set("rank", rank);
	if (status && excludeKey !== "status") u.set("status", status);
	if (materia && excludeKey !== "materia") u.set("materia", materia);
	const s = u.toString();
	return s ? `/?${s}` : "/";
}

const topMaterias = materiasList.data.slice(0, 50);
---

<Base
	title="Legislación Española Consolidada"
	description="Más de 12.000 leyes españolas con historial completo de cambios. Busca, compara versiones y consulta 190 años de legislación consolidada."
	ogTitle="Ley Abierta — Todas las leyes de España, actualizadas y accesibles"
	ogDescription="Más de 12.000 leyes españolas con historial completo de cambios. Consulta, compara y entiende la legislación."
	canonicalUrl="/"
>
	<style>
		.hero { text-align: center; padding: 2.5rem 0 2rem; }
		.hero h1 {
			font-family: var(--font-serif);
			font-size: 2.25rem;
			font-weight: 700;
			line-height: 1.15;
			letter-spacing: -0.02em;
		}
		.hero-sub {
			color: var(--text-secondary);
			font-size: 1rem;
			margin-top: 0.75rem;
			max-width: 38rem;
			margin-left: auto;
			margin-right: auto;
			line-height: 1.7;
		}

		/* ── Search ── */
		.search-form { margin-bottom: 1.75rem; }
		.search-row { display: flex; gap: 0.5rem; margin-bottom: 0.5rem; }
		.search-input {
			flex: 1; padding: 0.75rem 1rem;
			border: 1px solid var(--border); border-radius: 8px;
			background: var(--surface); color: var(--text);
			font-size: 1rem; font-family: var(--font-sans);
		}
		.search-input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px var(--accent-bg); }
		.filter-toggle {
			display: inline-flex; align-items: center; gap: 0.375rem;
			background: var(--surface); border: 1px solid var(--border); border-radius: 6px;
			color: var(--text-muted); font-size: 0.8125rem; font-family: var(--font-sans);
			font-weight: 500; cursor: pointer; padding: 0.35rem 0.75rem; transition: all 0.15s;
		}
		.filter-toggle:hover { color: var(--text-secondary); border-color: var(--accent); }
		.filter-toggle .arrow { transition: transform 0.2s; font-size: 0.625rem; }
		.filter-toggle.open .arrow { transform: rotate(180deg); }
		.filter-panel { display: none; margin-top: 0.5rem; }
		.filter-panel.open { display: block; }
		.filter-row { display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; }
		.filter-select {
			padding: 0.5rem 0.625rem; border: 1px solid var(--border); border-radius: 6px;
			background: var(--surface); color: var(--text-secondary); font-size: 0.875rem; font-family: var(--font-sans);
		}
		.filter-select:focus { outline: none; border-color: var(--accent); }
		.clear-filters { font-size: 0.75rem; color: var(--text-muted); margin-left: 0.25rem; }

		/* ── Active filters ── */
		.active-filters { display: flex; gap: 0.375rem; flex-wrap: wrap; margin-bottom: 0.75rem; }
		.active-filter {
			display: inline-flex; align-items: center; gap: 0.25rem;
			padding: 0.2rem 0.5rem; background: var(--accent-bg); color: var(--accent);
			border-radius: 100px; font-size: 0.75rem; font-weight: 500;
		}
		.active-filter-remove {
			width: 1rem; height: 1rem; border-radius: 50%; font-size: 0.625rem;
			color: var(--accent); opacity: 0.6; text-decoration: none;
			display: inline-flex; align-items: center; justify-content: center;
		}
		.active-filter-remove:hover { opacity: 1; text-decoration: none; }

		/* ── Results ── */
		.results-info { font-size: 0.8125rem; color: var(--text-muted); margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--border-light); }
		.law-card { padding: 1rem; margin: 0 -1rem; border-radius: 8px; transition: background 0.15s; }
		.law-card:hover { background: var(--surface); }
		.law-card + .law-card { border-top: 1px solid var(--border-light); }
		.law-card-title { font-family: var(--font-serif); font-weight: 600; font-size: 1.0625rem; line-height: 1.45; color: var(--text); }
		.law-card-title:hover { color: var(--accent); text-decoration: none; }
		.law-card-meta { margin-top: 0.5rem; display: flex; gap: 0.625rem; flex-wrap: wrap; align-items: center; font-size: 0.8125rem; color: var(--text-muted); }

		/* ── Landing sections ── */
		.section { margin-top: 3rem; }
		.section-title {
			font-family: var(--font-serif); font-size: 1.25rem; font-weight: 700;
			margin-bottom: 1rem; letter-spacing: -0.01em;
		}

		/* Jurisdictions grid */
		.juri-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 0.5rem; }
		.juri-card {
			display: flex; justify-content: space-between; align-items: center;
			padding: 0.75rem 1rem; background: var(--surface); border: 1px solid var(--border-light);
			border-radius: 8px; font-size: 0.875rem; color: var(--text); transition: all 0.15s;
		}
		.juri-card:hover { border-color: var(--accent); color: var(--accent); text-decoration: none; }
		.juri-count { font-family: var(--font-sans); font-variant-numeric: tabular-nums; font-size: 0.75rem; color: var(--text-muted); }

		/* Most reformed */
		.reformed-list { list-style: none; padding: 0; }
		.reformed-item {
			display: flex; gap: 1rem; align-items: baseline;
			padding: 0.75rem 0; border-bottom: 1px solid var(--border-light);
		}
		.reformed-item:last-child { border-bottom: none; }
		.reformed-count {
			font-family: var(--font-sans); font-variant-numeric: tabular-nums; font-size: 1.125rem; font-weight: 700;
			color: var(--accent); min-width: 2.5rem; text-align: right; flex-shrink: 0;
		}
		.reformed-title { font-size: 0.875rem; color: var(--text); line-height: 1.5; }
		.reformed-title:hover { color: var(--accent); text-decoration: none; }
		.reformed-rank { font-size: 0.6875rem; color: var(--text-muted); }

		/* Recent reforms */
		.recent-list { list-style: none; padding: 0; }
		.recent-item {
			display: flex; gap: 0.75rem; align-items: baseline;
			padding: 0.625rem 0; border-bottom: 1px solid var(--border-light);
		}
		.recent-item:last-child { border-bottom: none; }
		.recent-date {
			font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted);
			min-width: 5.5rem; flex-shrink: 0;
		}
		.recent-title { font-size: 0.875rem; color: var(--text); line-height: 1.5; }
		.recent-title:hover { color: var(--accent); text-decoration: none; }

		/* Two-column layout for bottom sections */
		.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }

		@media (max-width: 640px) {
			.hero h1 { font-size: 1.625rem; }
			.search-row { flex-direction: column; }
			.filter-row { flex-direction: column; }
			.filter-select { width: 100%; }
			.two-col { grid-template-columns: 1fr; }
			.juri-grid { grid-template-columns: repeat(2, 1fr); }
		}
	</style>

	<!-- Hero -->
	<div class="hero">
		<h1>Todas las leyes de España,<br>actualizadas y accesibles</h1>
		<p class="hero-sub">
			Más de {stats ? stats.norms.toLocaleString("es") : "12.000"} leyes
			y {stats ? stats.articles.toLocaleString("es") : "435.000"} artículos desde 1835.
			Consulta el texto completo, compara versiones y sigue los cambios de cualquier ley.
		</p>
	</div>

	<!-- Search -->
	<form method="get" action="/" class="search-form">
		<div class="search-row">
			<input type="search" name="q" value={q} placeholder="Buscar leyes..." class="search-input" />
			<button type="submit" class="btn btn-primary">Buscar</button>
		</div>
		<button type="button" class={`filter-toggle${hasSearch ? " open" : ""}`} id="filter-toggle">
			<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
			Filtros <span class="arrow">&#9660;</span>
		</button>
		<div class={`filter-panel${hasSearch ? " open" : ""}`} id="filter-panel">
			<div class="filter-row">
				<select name="rank" class="filter-select">
					<option value="">Todos los rangos</option>
					{ranks.data.map((r) => (
						<option value={r.rank} selected={r.rank === rank}>{RANK_LABELS[r.rank] ?? r.rank} ({r.count})</option>
					))}
				</select>
				<select name="status" class="filter-select">
					<option value="">Todos los estados</option>
					<option value="vigente" selected={status === "vigente"}>Vigente</option>
					<option value="derogada" selected={status === "derogada"}>Derogada</option>
				</select>
				{topMaterias.length > 0 && (
					<select name="materia" class="filter-select">
						<option value="">Todas las materias</option>
						{topMaterias.map((m) => (
							<option value={m.materia} selected={m.materia === materia}>{m.materia} ({m.count})</option>
						))}
					</select>
				)}
				{hasSearch && <a href="/" class="clear-filters">Limpiar</a>}
			</div>
		</div>
	</form>

	{/* Active filter chips */}
	{hasSearch && (
		<div class="active-filters">
			{q && <span class="active-filter">"{q}" <a href={buildUrlWithout("q")} class="active-filter-remove">&times;</a></span>}
			{rank && <span class="active-filter">{RANK_LABELS[rank] ?? rank} <a href={buildUrlWithout("rank")} class="active-filter-remove">&times;</a></span>}
			{status && <span class="active-filter">{status} <a href={buildUrlWithout("status")} class="active-filter-remove">&times;</a></span>}
			{materia && <span class="active-filter">{materia} <a href={buildUrlWithout("materia")} class="active-filter-remove">&times;</a></span>}
		</div>
	)}

	{/* ── Search results mode ── */}
	{hasSearch && (
		<>
			{result.data.length === 0 ? (
				<div style="text-align: center; padding: 3rem; color: var(--text-muted);">
					No se encontraron resultados{q ? ` para "${q}"` : ""}.
				</div>
			) : (
				<div>
					<div class="results-info">
						Mostrando {offset + 1}–{Math.min(offset + limit, result.total)} de {result.total.toLocaleString("es")}
						{q && <> para <strong>"{q}"</strong></>}
					</div>
					{result.data.map((law) => (
						<article class="law-card">
							<a href={`/laws/${law.id}`} class="law-card-title">{law.title}</a>
							<div class="law-card-meta">
								<span class={`badge badge-${law.status}`}>{law.status}</span>
								<span>{RANK_LABELS[law.rank] ?? law.rank}</span>
								<span>{law.published_at}</span>
								<span style="font-family: var(--font-mono); font-size: 0.6875rem; opacity: 0.6;">{law.id}</span>
							</div>
						</article>
					))}
				</div>
			)}

			{totalPages > 1 && (
				<nav class="pagination">
					{page > 1 && <a href={buildPageUrl(page - 1)} class="btn" style="margin-right: 0.25rem;">&larr;</a>}
					{pageNumbers(page, totalPages).map(p =>
						p === "..." ? <span class="page-ellipsis">...</span>
						: <a href={buildPageUrl(p)} class={`page-num${p === page ? " current" : ""}`}>{p}</a>
					)}
					{page < totalPages && <a href={buildPageUrl(page + 1)} class="btn" style="margin-left: 0.25rem;">&rarr;</a>}
				</nav>
			)}
		</>
	)}

	{/* ── Landing page mode ── */}
	{!hasSearch && jurisdictions && (
		<>
			{/* Jurisdictions */}
			<div class="section">
				<h2 class="section-title">Explora por comunidad autónoma</h2>
				<div class="juri-grid">
					{jurisdictions.data.map(j => (
						<a href={`/?q=&rank=&status=&materia=&page=1`} class="juri-card">
							{JURISDICTION_LABELS[j.jurisdiction] ?? j.jurisdiction}
							<span class="juri-count">{j.count.toLocaleString("es")}</span>
						</a>
					))}
				</div>
			</div>

			{/* Two-column: Most reformed + Recent reforms */}
			<div class="two-col section">
				<div>
					<h2 class="section-title">Leyes que más han cambiado</h2>
					<ul class="reformed-list">
						{mostReformed!.data.map(law => (
							<li class="reformed-item">
								<span class="reformed-count">{law.reform_count}</span>
								<div>
									<a href={`/laws/${law.id}`} class="reformed-title">{law.title}</a>
									<div class="reformed-rank">{RANK_LABELS[law.rank] ?? law.rank}</div>
								</div>
							</li>
						))}
					</ul>
				</div>
				<div>
					<h2 class="section-title">Cambios recientes</h2>
					<ul class="recent-list">
						{recentReforms!.data.map(r => (
							<li class="recent-item">
								<span class="recent-date">{r.date}</span>
								<a href={`/laws/${r.norm_id}`} class="recent-title">{r.title}</a>
							</li>
						))}
					</ul>
				</div>
			</div>
		</>
	)}

	<script is:inline>
		document.getElementById("filter-toggle")?.addEventListener("click", function () {
			this.classList.toggle("open");
			document.getElementById("filter-panel")?.classList.toggle("open");
		});
	</script>
</Base>
