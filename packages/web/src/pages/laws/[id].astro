---
import Base from "../../layouts/Base.astro";
import { getLaw, getLawAnalisis } from "../../lib/api";

const { id } = Astro.params;
if (!id) return Astro.redirect("/");

let law;
let analisis;
try {
	[law, analisis] = await Promise.all([
		getLaw(id),
		getLawAnalisis(id),
	]);
} catch {
	return Astro.redirect("/");
}

const RANK_LABELS: Record<string, string> = {
	constitucion: "Constitución",
	ley_organica: "Ley Orgánica",
	ley: "Ley",
	real_decreto_ley: "Real Decreto-ley",
	real_decreto_legislativo: "Real Decreto Legislativo",
	real_decreto: "Real Decreto",
	orden: "Orden",
	decreto: "Decreto",
	circular: "Circular",
	resolucion: "Resolución",
	acuerdo_internacional: "Acuerdo Internacional",
};

function cleanText(block: { title: string; current_text: string }): string {
	let text = block.current_text.trim();
	const title = block.title.replace(/[\[\]]/g, "").trim();
	if (title && text.startsWith(title)) {
		text = text.slice(title.length).trim();
	}
	return text;
}

const contentBlocks = law.blocks
	.filter(b => b.current_text && b.current_text.trim().length > 0)
	.map(b => ({
		...b,
		cleanedText: cleanText(b),
		displayTitle: b.title && !b.title.startsWith("[")
			? b.title
			: b.block_type === "preambulo" ? "Preambulo"
			: b.block_type === "firma" ? "Firma"
			: null,
	}))
	.filter(b => b.cleanedText.length > 0);

const hasAnalisis = analisis.materias.length > 0
	|| analisis.notas.length > 0
	|| analisis.referencias.anteriores.length > 0
	|| analisis.referencias.posteriores.length > 0;

// Group posteriores by relation type
const postByRelation = new Map<string, Array<{ normId: string; text: string }>>();
for (const ref of analisis.referencias.posteriores) {
	const key = ref.relation || "OTROS";
	if (!postByRelation.has(key)) postByRelation.set(key, []);
	postByRelation.get(key)!.push(ref);
}
const antByRelation = new Map<string, Array<{ normId: string; text: string }>>();
for (const ref of analisis.referencias.anteriores) {
	const key = ref.relation || "OTROS";
	if (!antByRelation.has(key)) antByRelation.set(key, []);
	antByRelation.get(key)!.push(ref);
}
---

<Base
	title={law.short_title || law.title}
	description={`${RANK_LABELS[law.rank] ?? law.rank} · ${law.status} · Publicada ${law.published_at} · ${law.department}`}
	ogTitle={law.short_title || law.title}
	ogDescription={`${RANK_LABELS[law.rank] ?? law.rank} · ${law.status} · Publicada ${law.published_at} · ${law.department}`}
	ogType="article"
	canonicalUrl={`/laws/${id}`}
>
	<style>
		.back-link { font-size: 0.8125rem; color: var(--text-muted); }
		.back-link:hover { color: var(--text-secondary); }

		/* ── Header area ── */
		.law-header {
			display: flex;
			justify-content: space-between;
			align-items: flex-start;
			gap: 1rem;
			margin: 0.75rem 0 0.5rem;
		}
		.law-title {
			font-family: var(--font-serif);
			font-size: 1.375rem;
			font-weight: 700;
			line-height: 1.35;
			letter-spacing: -0.01em;
			flex: 1;
		}
		.boe-btn {
			display: inline-flex;
			align-items: center;
			gap: 0.375rem;
			padding: 0.4rem 0.875rem;
			border: 1.5px solid var(--border);
			border-radius: 6px;
			font-size: 0.8125rem;
			font-weight: 600;
			color: var(--text-secondary);
			background: var(--surface);
			white-space: nowrap;
			flex-shrink: 0;
			transition: all 0.15s;
		}
		.boe-btn:hover { border-color: var(--accent); color: var(--accent); text-decoration: none; }

		.meta-row {
			display: flex;
			flex-wrap: wrap;
			gap: 0.5rem;
			align-items: center;
			font-size: 0.8125rem;
			color: var(--text-muted);
			margin-bottom: 1.5rem;
			line-height: 1.4;
		}
		.meta-sep { color: var(--border); }
		.meta-item {
			display: inline-flex;
			align-items: center;
			gap: 0.3rem;
		}
		.meta-item svg { flex-shrink: 0; }

		/* ── Tabs ── */
		.tabs { display: flex; gap: 0; border-bottom: 1px solid var(--border); }
		.tab {
			padding: 0.5rem 1rem;
			font-size: 0.8125rem;
			font-weight: 500;
			color: var(--text-muted);
			cursor: pointer;
			border: none;
			background: none;
			border-bottom: 2px solid transparent;
			margin-bottom: -1px;
			font-family: var(--font-sans);
		}
		.tab:hover { color: var(--text); }
		.tab.active { color: var(--accent); border-bottom-color: var(--accent); }
		.tab-badge {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			min-width: 1.25rem;
			height: 1.25rem;
			padding: 0 0.3rem;
			border-radius: 100px;
			background: var(--accent-bg);
			color: var(--accent);
			font-size: 0.6875rem;
			font-weight: 600;
			margin-left: 0.375rem;
		}
		.tab-panel { display: none; padding-top: 1.5rem; }
		.tab-panel.active { display: block; }

		/* ── Timeline ── */
		.timeline { list-style: none; padding: 0; }
		.timeline-item { position: relative; padding: 0 0 1rem 1.5rem; }
		.timeline-item::before { content: ""; position: absolute; left: 0.28rem; top: 0.5rem; bottom: -0.25rem; width: 1px; background: var(--border); }
		.timeline-item:last-child::before { display: none; }
		.timeline-dot { position: absolute; left: 0; top: 0.35rem; width: 0.625rem; height: 0.625rem; border-radius: 50%; border: 2px solid var(--border); background: var(--bg); }
		.timeline-item:last-child .timeline-dot { border-color: var(--accent); background: var(--accent); }
		.timeline-date { font-weight: 600; font-size: 0.8125rem; font-variant-numeric: tabular-nums; }
		.timeline-detail { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.125rem; }
		.timeline-source { font-family: var(--font-mono); font-size: 0.6875rem; }
		.timeline-link { font-size: 0.75rem; margin-top: 0.25rem; display: inline-block; }

		/* ── Content blocks ── */
		.law-content { font-family: var(--font-serif); line-height: 1.8; font-size: 0.9375rem; }
		.block-section { margin-bottom: 1.75rem; padding-bottom: 1.75rem; border-bottom: 1px solid var(--border-light); }
		.block-section:last-child { border-bottom: none; }
		.block-title { font-family: var(--font-sans); font-weight: 600; font-size: 0.8125rem; color: var(--accent); margin-bottom: 0.625rem; }
		.block-text { color: var(--text); white-space: pre-line; }
		.block-text.collapsed { max-height: 14rem; overflow: hidden; position: relative; }
		.block-text.collapsed::after { content: ""; position: absolute; bottom: 0; left: 0; right: 0; height: 4rem; background: linear-gradient(transparent, var(--bg)); pointer-events: none; }
		.expand-btn { display: inline-block; margin-top: 0.375rem; font-size: 0.8125rem; color: var(--accent-light); cursor: pointer; background: none; border: none; font-family: var(--font-sans); padding: 0; }
		.expand-btn:hover { text-decoration: underline; }

		/* ── Quick stats with icons ── */
		.quick-stats {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
			gap: 0.75rem;
			margin-bottom: 1.5rem;
		}
		.stat-card {
			display: flex;
			align-items: center;
			gap: 0.625rem;
			padding: 0.875rem 1rem;
			background: var(--surface);
			border: 1px solid var(--border-light);
			border-radius: 10px;
		}
		.stat-icon { color: var(--accent-light); opacity: 0.6; flex-shrink: 0; }
		.stat-value { font-family: var(--font-sans); font-variant-numeric: tabular-nums; font-size: 1.25rem; font-weight: 700; color: var(--accent); line-height: 1.2; }
		.stat-label { font-size: 0.6875rem; color: var(--text-muted); text-transform: none; letter-spacing: 0.04em; }

		/* ── Cards ── */
		.card {
			background: var(--surface);
			border: 1px solid var(--border-light);
			border-radius: 10px;
			padding: 1.25rem 1.5rem;
			margin-bottom: 1rem;
		}
		.card-heading {
			font-size: 1rem;
			font-weight: 600;
			margin-bottom: 0.75rem;
			display: flex;
			align-items: center;
			gap: 0.5rem;
		}
		.card-heading-icon { color: var(--accent-light); opacity: 0.6; }

		/* ── Datos generales grid ── */
		.meta-grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 1.25rem;
			font-size: 0.875rem;
		}
		.meta-item-label { color: var(--text-muted); font-size: 0.8125rem; margin-bottom: 0.125rem; }
		.meta-item-value { color: var(--text); font-weight: 500; }

		/* ── Flat sections (no card) ── */
		.section { margin-bottom: 2rem; }
		.section-heading {
			font-size: 1.0625rem;
			font-weight: 600;
			margin-bottom: 0.75rem;
			padding-bottom: 0.5rem;
			border-bottom: 1px solid var(--border-light);
		}

		/* ── References ── */
		.ref-group { margin-bottom: 1.25rem; }
		.ref-relation { font-size: 0.875rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 0.375rem; }
		.ref-list { list-style: disc; padding-left: 1.5rem; margin: 0; }
		.ref-list li { font-size: 0.875rem; line-height: 1.65; color: var(--text-secondary); margin-bottom: 0.375rem; }
		.ref-list a { font-family: var(--font-mono); font-size: 0.8125rem; }
		.materia-tag {
			display: inline-block;
			padding: 0.25rem 0.75rem;
			border: 1px solid var(--border);
			border-radius: 100px;
			font-size: 0.8125rem;
			color: var(--text-secondary);
			margin: 0.125rem 0.25rem 0.125rem 0;
			transition: all 0.15s;
		}
		.materia-tag:hover { background: var(--accent-bg); color: var(--accent); border-color: var(--accent); text-decoration: none; }
		.nota-item { font-size: 0.8125rem; color: var(--text-secondary); line-height: 1.6; margin-bottom: 0.375rem; }

		@media (max-width: 640px) {
			.law-header { flex-direction: column; }
			.meta-grid { grid-template-columns: 1fr; }
			.quick-stats { grid-template-columns: repeat(2, 1fr); }
		}
	</style>

	<a href="/" class="back-link">&larr; Volver a búsqueda</a>

	<div class="law-header">
		<div>
			<div style="display: flex; gap: 0.375rem; margin-bottom: 0.375rem;">
				<span class={`badge badge-${law.status}`}>{law.status}</span>
				<span class="badge" style="background: var(--accent-bg); color: var(--accent);">{RANK_LABELS[law.rank] ?? law.rank}</span>
			</div>
			<h1 class="law-title">{law.title}</h1>
		</div>
		<a href={`https://www.boe.es/buscar/act.php?id=${law.id}`} target="_blank" rel="noopener" class="boe-btn">
			<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
			Ver en BOE
		</a>
	</div>

	<div class="meta-row">
		<span class="meta-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg> Publicado: {law.published_at}</span>
		{law.updated_at && law.updated_at !== law.published_at && (
			<>
				<span class="meta-sep">·</span>
				<span class="meta-item">Act. {law.updated_at}</span>
			</>
		)}
		<span class="meta-sep">·</span>
		<span class="meta-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg> {law.department}</span>
		<span class="meta-sep">·</span>
		<span style="font-family: var(--font-mono); font-size: 0.8125rem; opacity: 0.5; position: relative; top: 1px;">{id}</span>
	</div>

	<!-- Tabs -->
	<div class="tabs">
		<button class="tab active" data-tab="resumen">Resumen</button>
		<button class="tab" data-tab="texto">Texto completo</button>
		{law.reforms.length > 1 && (
			<button class="tab" data-tab="reformas">Historial de cambios <span class="tab-badge">{law.reforms.length}</span></button>
		)}
	</div>

	<!-- Tab: Resumen (default) -->
	<div class="tab-panel active" id="tab-resumen">
		<div class="quick-stats">
			<div class="stat-card">
				<svg class="stat-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
				<div>
					<div class="stat-value">{law.blocks.length}</div>
					<div class="stat-label">Artículos</div>
				</div>
			</div>
			<div class="stat-card">
				<svg class="stat-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 0 0 9 9"/></svg>
				<div>
					<div class="stat-value">{law.reforms.length}</div>
					<div class="stat-label">Versiones</div>
				</div>
			</div>
			{analisis.materias.length > 0 && (
				<div class="stat-card">
					<svg class="stat-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
					<div>
						<div class="stat-value">{analisis.materias.length}</div>
						<div class="stat-label">Temas</div>
					</div>
				</div>
			)}
			{(analisis.referencias.anteriores.length + analisis.referencias.posteriores.length) > 0 && (
				<div class="stat-card">
					<svg class="stat-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
					<div>
						<div class="stat-value">{analisis.referencias.anteriores.length + analisis.referencias.posteriores.length}</div>
						<div class="stat-label">Referencias</div>
					</div>
				</div>
			)}
		</div>

		<div class="card">
			<h3 class="card-heading">
				<svg class="card-heading-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
				Información general
			</h3>
			<div class="meta-grid">
				<div>
					<div class="meta-item-label">Rango</div>
					<div class="meta-item-value">{RANK_LABELS[law.rank] ?? law.rank}</div>
				</div>
				<div>
					<div class="meta-item-label">Estado</div>
					<div class="meta-item-value"><span class={`badge badge-${law.status}`}>{law.status}</span></div>
				</div>
				<div>
					<div class="meta-item-label">Publicación</div>
					<div class="meta-item-value">{law.published_at}</div>
				</div>
				{law.updated_at && law.updated_at !== law.published_at && (
					<div>
						<div class="meta-item-label">Última actualización</div>
						<div class="meta-item-value">{law.updated_at}</div>
					</div>
				)}
				<div>
					<div class="meta-item-label">Departamento</div>
					<div class="meta-item-value">{law.department}</div>
				</div>
				{law.reforms.length > 1 && (
					<div>
						<div class="meta-item-label">Periodo de reformas</div>
						<div class="meta-item-value">{law.reforms[0]!.date} — {law.reforms[law.reforms.length - 1]!.date}</div>
					</div>
				)}
			</div>
		</div>

		{analisis.notas.length > 0 && (
			<div class="section">
				<h3 class="section-heading">Notas</h3>
				{analisis.notas.map(nota => (
					<p class="nota-item">{nota}</p>
				))}
			</div>
		)}

		{analisis.referencias.anteriores.length > 0 && (
			<div class="section">
				<h3 class="section-heading">Esta ley se basa en</h3>
				{[...antByRelation.entries()].map(([relation, refs]) => (
					<div class="ref-group">
						<div class="ref-relation">{relation}:</div>
						<ul class="ref-list">
							{refs.map(ref => {
								const cleanText = ref.text.replace(/^[,\s]+/, "").replace(/[,\s]+$/, "");
								return (
									<li>
										{cleanText}{cleanText ? " " : ""}
										{ref.normId && <a href={`/laws/${ref.normId}`}>{ref.normId}</a>}
									</li>
								);
							})}
						</ul>
					</div>
				))}
			</div>
		)}

		{analisis.referencias.posteriores.length > 0 && (
			<div class="section">
				<h3 class="section-heading">Leyes que modifican esta</h3>
				{[...postByRelation.entries()].map(([relation, refs]) => (
					<div class="ref-group">
						<div class="ref-relation">{relation}:</div>
						<ul class="ref-list">
							{refs.map(ref => {
								const cleanText = ref.text.replace(/^[,\s]+/, "").replace(/[,\s]+$/, "");
								return (
									<li>
										{cleanText}{cleanText ? " " : ""}
										{ref.normId && <a href={`/laws/${ref.normId}`}>{ref.normId}</a>}
									</li>
								);
							})}
						</ul>
					</div>
				))}
			</div>
		)}

		{analisis.materias.length > 0 && (
			<div class="section">
				<h3 class="section-heading">Temas</h3>
				<div>
					{analisis.materias.map(m => (
						<a href={`/?materia=${encodeURIComponent(m)}`} class="materia-tag">{m}</a>
					))}
				</div>
			</div>
		)}
	</div>

	<!-- Tab: Texto -->
	<div class="tab-panel" id="tab-texto">
		<div class="law-content">
			{contentBlocks.map((block) => {
				const isLong = block.cleanedText.length > 2000;
				return (
					<div class="block-section">
						{block.displayTitle && <div class="block-title">{block.displayTitle}</div>}
						<div class={`block-text${isLong ? " collapsed" : ""}`}>
							{block.cleanedText}
						</div>
						{isLong && (
							<button class="expand-btn" onclick="
								const text = this.previousElementSibling;
								if (text.classList.contains('collapsed')) {
									text.classList.remove('collapsed');
									this.textContent = 'Mostrar menos';
								} else {
									text.classList.add('collapsed');
									this.textContent = 'Leer más...';
								}
							">Leer más...</button>
						)}
					</div>
				);
			})}
		</div>
	</div>

	<!-- Tab: Reformas -->
	{law.reforms.length > 1 && (
		<div class="tab-panel" id="tab-reformas">
			<ul class="timeline">
				{law.reforms.map((reform, i) => {
					const isFirst = i === 0;
					const prevDate = i > 0 ? law.reforms[i - 1]!.date : null;
					const diffUrl = prevDate ? `/laws/${id}/diff?from=${prevDate}&to=${reform.date}` : null;
					return (
						<li class="timeline-item">
							<div class="timeline-dot"></div>
							<div class="timeline-date">{reform.date}</div>
							<div class="timeline-detail">
								{isFirst ? "Versión original" : `${reform.affected_blocks.length} artículos modificados`}
								{" "}<span class="timeline-source">{reform.source_id}</span>
							</div>
							{diffUrl && <a href={diffUrl} class="timeline-link">Ver cambios &rarr;</a>}
						</li>
					);
				})}
			</ul>
		</div>
	)}

	<script is:inline>
		document.querySelectorAll('.tab').forEach(tab => {
			tab.addEventListener('click', () => {
				document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
				document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
				tab.classList.add('active');
				document.getElementById('tab-' + tab.dataset.tab)?.classList.add('active');
				tab.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
			});
		});
	</script>

	<!-- JSON-LD Structured Data -->
	<script
		type="application/ld+json"
		set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Legislation",
			name: law.title,
			datePublished: law.published_at,
			legislationDate: law.published_at,
			legislationType: RANK_LABELS[law.rank] ?? law.rank,
			inLanguage: "es",
			url: `https://leyabierta.es/laws/${id}`,
			publisher: {
				"@type": "Organization",
				name: "Agencia Estatal BOE",
				url: "https://www.boe.es",
			},
		})}
	/>
</Base>
