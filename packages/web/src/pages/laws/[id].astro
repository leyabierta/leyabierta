---
import { getCollection } from "astro:content";
import { promises as fs } from "node:fs";
import MarkdownIt from "markdown-it";
import Base from "../../layouts/Base.astro";
import { getLaw } from "../../lib/api.ts";

// Shift all heading levels down by 1 (h1→h2, h2→h3, etc.) so the page
// has a single H1 — the law title rendered in the header above the tabs.
const md = new MarkdownIt();
md.renderer.rules.heading_open = (tokens, idx, options, _env, self) => {
	const token = tokens[idx];
	const level = Math.min(Number(token.tag.slice(1)) + 1, 6);
	token.tag = `h${level}`;
	return self.renderToken(tokens, idx, options);
};
md.renderer.rules.heading_close = (tokens, idx, options, _env, self) => {
	const token = tokens[idx];
	const level = Math.min(Number(token.tag.slice(1)) + 1, 6);
	token.tag = `h${level}`;
	return self.renderToken(tokens, idx, options);
};

export async function getStaticPaths() {
	const laws = await getCollection("laws");
	return laws.map((entry) => ({
		params: { id: entry.data.identificador },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { id } = Astro.params;
const law = entry.data;

// Fetch citizen data (summary + tags) from the API at build time
let citizenSummary = "";
let citizenTags: string[] = [];
try {
	const detail = await getLaw(id!);
	citizenSummary = detail.citizen_summary ?? "";
	citizenTags = detail.citizen_tags ?? [];
} catch {
	// API may not be available during build — gracefully degrade
}

// Read and render the markdown body on-demand (not during content sync)
let htmlContent = "";
if (entry.body) {
	const raw = await fs.readFile(entry.body, "utf-8");
	const bodyMatch = raw.match(/^---[\s\S]*?---\s*([\s\S]*)$/);
	const body = bodyMatch?.[1] ?? raw;
	htmlContent = md.render(body);
}

const RANK_LABELS: Record<string, string> = {
	constitucion: "Constitución",
	ley_organica: "Ley Orgánica",
	ley: "Ley",
	real_decreto_ley: "Real Decreto-ley",
	real_decreto_legislativo: "Real Decreto Legislativo",
	real_decreto: "Real Decreto",
	orden: "Orden",
	decreto: "Decreto",
	circular: "Circular",
	resolucion: "Resolución",
	acuerdo_internacional: "Acuerdo Internacional",
	instruccion: "Instrucción",
	reglamento: "Reglamento",
};

const MONTHS = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
function formatDate(iso: string): string {
	if (!iso) return '';
	const [y, m, d] = iso.split('-');
	return `${parseInt(d!, 10)} de ${MONTHS[parseInt(m!, 10) - 1]} de ${y}`;
}

function capitalize(s: string): string {
	return s ? s.charAt(0).toUpperCase() + s.slice(1) : '';
}

const reforms = (law.reformas ?? []).slice().reverse();
const materias = law.materias ?? [];
const notas = law.notas ?? [];
const refsAnt = law.referencias_anteriores ?? [];
const refsPost = law.referencias_posteriores ?? [];
const articleCount = law.articulos ?? 0;
---

<Base
	title={law.titulo}
	description={`${RANK_LABELS[law.rango] ?? law.rango} · ${law.estado} · Publicada ${law.fecha_publicacion} · ${law.departamento}`}
	ogTitle={law.titulo}
	ogType="article"
	canonicalUrl={`/laws/${id}`}
>
	<!-- JSON-LD: Legislation -->
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "Legislation",
		"name": law.titulo,
		"identifier": law.identificador,
		"legislationDate": law.fecha_publicacion,
		"dateModified": law.ultima_actualizacion,
		"legislationJurisdiction": law.jurisdiccion === "es" ? "ES" : law.jurisdiccion.toUpperCase(),
		"inLanguage": "es",
		"url": `https://leyabierta.es/laws/${id}`,
		"isPartOf": { "@type": "WebSite", "@id": "https://leyabierta.es/#website" },
		...(law.fuente ? { "legislationLegalForce": law.estado === "vigente" ? "InForce" : "NotInForce", "sameAs": law.fuente } : {})
	})} />
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		"itemListElement": [
			{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://leyabierta.es/" },
			{ "@type": "ListItem", "position": 2, "name": law.titulo, "item": `https://leyabierta.es/laws/${id}` }
		]
	})} />
	<style>
		.back-link { font-size: 0.8125rem; color: var(--text-muted); }
		.back-link:hover { color: var(--text-secondary); }

		.law-header {
			display: flex;
			justify-content: space-between;
			align-items: flex-start;
			gap: 1rem;
			margin: 0.75rem 0 0.5rem;
		}
		.law-title {
			font-family: var(--font-serif);
			font-size: 1.375rem;
			font-weight: 700;
			line-height: 1.35;
			letter-spacing: -0.01em;
			flex: 1;
		}
		.boe-btn {
			display: inline-flex;
			align-items: center;
			gap: 0.375rem;
			padding: 0.4rem 0.875rem;
			border: 1.5px solid var(--border);
			border-radius: 6px;
			font-size: 0.8125rem;
			font-weight: 600;
			color: var(--text-secondary);
			background: var(--surface);
			white-space: nowrap;
			flex-shrink: 0;
			transition: all 0.15s;
		}
		.boe-btn:hover { border-color: var(--accent); color: var(--accent); text-decoration: none; }

		.meta-row {
			display: flex;
			flex-wrap: wrap;
			gap: 0.5rem;
			align-items: center;
			font-size: 0.8125rem;
			color: var(--text-muted);
			margin-bottom: 1.5rem;
			line-height: 1.4;
		}
		.meta-sep { color: var(--border); }
		.meta-item { display: inline-flex; align-items: center; gap: 0.3rem; }
		.meta-item svg { flex-shrink: 0; opacity: 0.5; }
		.meta-id { font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted); position: relative; top: 0.5px; }

		/* ── Tabs ── */
		.tabs { display: flex; gap: 0; border-bottom: 1px solid var(--border); }
		.tab {
			padding: 0.5rem 1rem;
			font-size: 0.8125rem;
			font-weight: 500;
			color: var(--text-muted);
			cursor: pointer;
			border: none;
			background: none;
			border-bottom: 2px solid transparent;
			margin-bottom: -1px;
			font-family: var(--font-sans);
		}
		.tab:hover { color: var(--text); }
		.tab.active { color: var(--accent); border-bottom-color: var(--accent); }
		.tab-badge {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			min-width: 1.25rem;
			height: 1.25rem;
			padding: 0 0.3rem;
			border-radius: 100px;
			background: var(--accent-bg);
			color: var(--accent);
			font-size: 0.6875rem;
			font-weight: 600;
			margin-left: 0.375rem;
		}
		.tab-panel { display: none; padding-top: 1.5rem; }
		.tab-panel.active { display: block; }

		/* ── Content ── */
		.law-content {
			font-family: var(--font-serif);
			line-height: 1.8;
			font-size: 0.9375rem;
			overflow-wrap: break-word;
			word-break: break-word;
		}
		.law-content :global(h2) { font-size: 1.25rem; font-weight: 700; margin: 2rem 0 0.75rem; text-align: center; text-transform: uppercase; letter-spacing: 0.02em; }
		.law-content :global(h3) { font-size: 1.0625rem; font-weight: 700; color: var(--accent); margin: 2rem 0 0.5rem; font-family: var(--font-sans); text-align: center; text-transform: uppercase; letter-spacing: 0.02em; }
		.law-content :global(h4) { font-size: 0.9375rem; font-weight: 600; margin: 1.5rem 0 0.5rem; text-align: center; color: var(--text-secondary); }
		.law-content :global(h6) { font-size: 0.9375rem; font-weight: 700; margin: 0.75rem 0 0.5rem; color: var(--text); }
		.law-content :global(p) { margin-bottom: 0.75rem; }
		.law-content :global(hr) { border: none; border-top: 1px solid var(--border-light); margin: 1.5rem 0 0.75rem; }

		/* ── Resumen components ── */
		/* ── Omnibus banner ── */
		.omnibus-banner {
			display: flex;
			align-items: center;
			gap: 0.75rem;
			padding: 0.875rem 1rem;
			background: var(--warning-bg, #fff3cd);
			border: 1px solid var(--warning-border, #ffc107);
			border-radius: 10px;
			margin-bottom: 1.25rem;
			text-decoration: none;
			transition: box-shadow 0.15s;
		}
		.omnibus-banner:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.08); text-decoration: none; }
		.omnibus-banner-badge {
			font-size: 0.75rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.04em;
			color: var(--warning, #856404);
			background: rgba(255,193,7,0.2);
			padding: 0.25rem 0.625rem;
			border-radius: 5px;
			white-space: nowrap;
		}
		.omnibus-banner-text {
			font-size: 0.875rem;
			color: var(--warning, #856404);
			line-height: 1.4;
		}

		/* ── View toggle ── */
		.view-toggle {
			display: inline-flex;
			align-items: center;
			gap: 0.375rem;
			padding: 0.5rem 0;
			border: none;
			background: none;
			font-size: 0.8125rem;
			font-weight: 500;
			color: var(--accent);
			cursor: pointer;
			font-family: var(--font-sans);
			margin-bottom: 1rem;
		}
		.view-toggle:hover { text-decoration: underline; }
		.technical-details {
			border-top: 1px solid var(--border-light);
			padding-top: 1.25rem;
			margin-top: 0.5rem;
		}

		.quick-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 0.75rem; margin-bottom: 1.5rem; }
		.stat-card { display: flex; align-items: center; gap: 0.625rem; padding: 0.875rem 1rem; background: var(--surface); border: 1px solid var(--border-light); border-radius: 10px; }
		.stat-value { font-variant-numeric: tabular-nums; font-size: 1.25rem; font-weight: 700; color: var(--accent); line-height: 1.2; }
		.stat-label { font-size: 0.6875rem; color: var(--text-muted); }

		.card { background: var(--surface); border: 1px solid var(--border-light); border-radius: 10px; padding: 1.25rem 1.5rem; margin-bottom: 1rem; }
		.card-heading { font-size: 1rem; font-weight: 600; margin-bottom: 0.75rem; }
		.meta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; font-size: 0.875rem; }
		.meta-item-label { color: var(--text-muted); font-size: 0.8125rem; margin-bottom: 0.125rem; }
		.meta-item-value { color: var(--text); font-weight: 500; }

		.citizen-summary {
			font-size: 1.0625rem;
			color: var(--text-secondary);
			line-height: 1.7;
			margin-bottom: 1.25rem;
			font-style: italic;
		}
		.citizen-summary-empty {
			font-size: 0.9375rem;
			color: var(--text-tertiary, var(--text-secondary));
			line-height: 1.6;
			margin-bottom: 1.25rem;
			padding: 1rem 1.25rem;
			background: var(--surface-alt, var(--surface));
			border-radius: 8px;
			border-left: 3px solid var(--border);
		}
		.citizen-tags {
			display: flex;
			flex-wrap: wrap;
			gap: 0.375rem;
			margin-bottom: 1.5rem;
		}
		.citizen-tag {
			display: inline-block;
			padding: 0.25rem 0.75rem;
			font-size: 0.8125rem;
			background: var(--accent-bg);
			color: var(--accent);
			border-radius: 100px;
			transition: all 0.15s;
		}
		.citizen-tag:hover { background: var(--accent); color: #fff; text-decoration: none; }

		.section { margin-bottom: 2rem; }
		.section-heading { font-size: 1.0625rem; font-weight: 600; margin-bottom: 0.75rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border-light); }
		.materia-tag { display: inline-block; padding: 0.25rem 0.75rem; border: 1px solid var(--border); border-radius: 100px; font-size: 0.8125rem; color: var(--text-secondary); margin: 0.125rem 0.25rem 0.125rem 0; transition: all 0.15s; }
		.materia-tag:hover { background: var(--accent-bg); color: var(--accent); border-color: var(--accent); text-decoration: none; }
		.ref-list { list-style: disc; padding-left: 1.5rem; margin: 0; }
		.ref-list li { font-size: 0.875rem; line-height: 1.65; color: var(--text-secondary); margin-bottom: 0.375rem; }
		.ref-list a { font-family: var(--font-mono); font-size: 0.8125rem; }
		.nota-item { font-size: 0.8125rem; color: var(--text-secondary); line-height: 1.6; margin-bottom: 0.375rem; }

		/* ── Timeline ── */
		.timeline { list-style: none; padding: 0; }
		.timeline-item { position: relative; padding: 0 0 1rem 1.5rem; }
		.timeline-item::before { content: ""; position: absolute; left: 0.28rem; top: 0.5rem; bottom: -0.25rem; width: 1px; background: var(--border); }
		.timeline-item:last-child::before { display: none; }
		.timeline-dot { position: absolute; left: 0; top: 0.35rem; width: 0.625rem; height: 0.625rem; border-radius: 50%; border: 2px solid var(--border); background: var(--bg); }
		.timeline-item:first-child .timeline-dot { border-color: var(--accent); background: var(--accent); }
		.timeline-date { font-weight: 600; font-size: 0.8125rem; }
		.timeline-detail { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.125rem; }
		.timeline-link { font-size: 0.75rem; margin-top: 0.25rem; display: inline-block; }

		/* ── Follow card ── */
		.follow-card {
			display: flex;
			gap: 1rem;
			align-items: flex-start;
			padding: 1.25rem 1.5rem;
			background: var(--accent-bg);
			border: 1px solid var(--border-light);
			border-radius: 10px;
			margin-top: 2rem;
		}
		.follow-icon {
			flex-shrink: 0;
			color: var(--accent);
			margin-top: 0.125rem;
		}
		.follow-content { flex: 1; min-width: 0; }
		.follow-heading {
			font-size: 0.9375rem;
			font-weight: 600;
			color: var(--text);
			margin: 0 0 0.25rem;
		}
		.follow-desc {
			font-size: 0.8125rem;
			color: var(--text-muted);
			margin: 0 0 0.75rem;
			line-height: 1.5;
		}
		.follow-input-row {
			display: flex;
			gap: 0.5rem;
		}
		.follow-input {
			flex: 1;
			min-width: 0;
			padding: 0.5rem 0.75rem;
			border: 1px solid var(--border);
			border-radius: 6px;
			font-size: 0.875rem;
			font-family: var(--font-sans);
			background: var(--bg);
			color: var(--text);
		}
		.follow-input:focus {
			outline: none;
			border-color: var(--accent);
			box-shadow: 0 0 0 2px rgba(26, 54, 93, 0.1);
		}
		.follow-btn {
			padding: 0.5rem 1rem;
			background: var(--accent);
			color: #fff;
			border: none;
			border-radius: 6px;
			font-size: 0.8125rem;
			font-weight: 600;
			font-family: var(--font-sans);
			cursor: pointer;
			white-space: nowrap;
			transition: background 0.15s;
		}
		.follow-btn:hover { background: #15294a; }
		.follow-btn:disabled { opacity: 0.6; cursor: not-allowed; }
		.follow-msg {
			font-size: 0.8125rem;
			line-height: 1.5;
			margin-top: 0.5rem;
		}
		.follow-msg.success { color: #16a34a; }
		.follow-msg.error { color: #dc2626; }

		@media (max-width: 640px) {
			.law-header { flex-direction: column; }
			.meta-grid { grid-template-columns: 1fr; }
			.quick-stats { grid-template-columns: repeat(2, 1fr); }
			.tabs { overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
			.tabs::-webkit-scrollbar { display: none; }
			.tab { white-space: nowrap; flex-shrink: 0; font-size: 0.75rem; padding: 0.5rem 0.75rem; }
			.law-content { font-size: 0.875rem; }
			.follow-card { flex-direction: column; gap: 0.5rem; }
			.follow-icon { display: none; }
			.follow-input-row { flex-direction: column; }
		}
	</style>

	<a href="/" class="back-link" id="back-link">&larr; Volver</a>
	<script is:inline>
		(function() {
			var link = document.getElementById("back-link");
			if (document.referrer && document.referrer.indexOf(location.origin) === 0) {
				link.addEventListener("click", function(e) {
					e.preventDefault();
					history.back();
				});
				var refPath = new URL(document.referrer).pathname;
				if (refPath === "/" || refPath.indexOf("/?") === 0) {
					link.textContent = "\u2190 Volver a resultados";
				} else if (refPath === "/cambios") {
					link.textContent = "\u2190 Volver a cambios recientes";
				} else if (refPath === "/mis-cambios") {
					link.textContent = "\u2190 Volver a mis cambios";
				}
			}
		})();
	</script>

	<div class="law-header">
		<div>
			<div style="display: flex; gap: 0.375rem; margin-bottom: 0.375rem;">
				<span class={`badge badge-${law.estado}`}>{law.estado}</span>
				<span class="badge" style="background: var(--accent-bg); color: var(--accent);">{RANK_LABELS[law.rango] ?? law.rango}</span>
			</div>
			<h1 class="law-title">{law.titulo}</h1>
		</div>
		<a href={`https://www.boe.es/buscar/act.php?id=${law.identificador}`} target="_blank" rel="noopener" class="boe-btn">
			<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
			Ver en BOE
		</a>
	</div>

	<div class="meta-row">
		<span class="meta-item">
			<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
			{formatDate(law.fecha_publicacion)}
		</span>
		{law.ultima_actualizacion && law.ultima_actualizacion !== law.fecha_publicacion && (
			<>
				<span class="meta-sep">&middot;</span>
				<span class="meta-item">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M12 7v5l4 2"/></svg>
					{formatDate(law.ultima_actualizacion)}
				</span>
			</>
		)}
		<span class="meta-sep">&middot;</span>
		<span class="meta-item">
			<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" x2="21" y1="22" y2="22"/><line x1="6" x2="6" y1="18" y2="11"/><line x1="10" x2="10" y1="18" y2="11"/><line x1="14" x2="14" y1="18" y2="11"/><line x1="18" x2="18" y1="18" y2="11"/><polygon points="12 2 20 7 4 7"/></svg>
			{law.departamento}
		</span>
		<span class="meta-sep">&middot;</span>
		<span class="meta-item meta-id">{id}</span>
	</div>

	<!-- Tabs -->
	<div class="tabs">
		<button class="tab active" data-tab="resumen">Resumen</button>
		<button class="tab" data-tab="reformas">Historial de cambios{reforms.length > 1 && <span class="tab-badge">{reforms.length}</span>}</button>
		<button class="tab" data-tab="texto">Texto completo</button>
	</div>

	<!-- Tab: Resumen (static) -->
	<div class="tab-panel active" id="tab-resumen">
		{materias.length >= 15 && (
			<a href={`/omnibus/detalle?id=${id}`} class="omnibus-banner">
				<span class="omnibus-banner-badge">Ley ómnibus</span>
				<span class="omnibus-banner-text">Esta ley agrupa {materias.length} temas distintos en una sola norma. Ver desglose por temas →</span>
			</a>
		)}

		<!-- Citizen view (default) -->
		{citizenSummary ? (
			<p class="citizen-summary">{citizenSummary}</p>
		) : (
			<p class="citizen-summary-empty">Todavía no hemos generado un resumen simplificado para esta ley. Mientras tanto, puedes consultar el texto completo en la pestaña correspondiente.</p>
		)}

		{citizenTags.length > 0 && (
			<div class="citizen-tags">
				{citizenTags.map((tag) => (
					<a href={`/?citizen_tag=${encodeURIComponent(tag)}`} class="citizen-tag">{tag}</a>
				))}
			</div>
		)}

		<div class="quick-stats">
			{articleCount > 0 && (
				<div class="stat-card"><div><div class="stat-value">{articleCount}</div><div class="stat-label">Artículos</div></div></div>
			)}
			{reforms.length > 0 && (
				<div class="stat-card"><div><div class="stat-value">{reforms.length}</div><div class="stat-label">Versiones</div></div></div>
			)}
			{materias.length > 0 && (
				<div class="stat-card"><div><div class="stat-value">{materias.length}</div><div class="stat-label">Temas</div></div></div>
			)}
		</div>

		<!-- Toggle for technical details -->
		<button type="button" class="view-toggle" id="view-toggle" aria-expanded="false">
			Ver información completa ▸
		</button>

		<!-- Technical view (hidden by default) -->
		<div class="technical-details" id="technical-details" style="display:none;">
			<div class="card">
				<h3 class="card-heading">Información general</h3>
				<div class="meta-grid">
					<div><div class="meta-item-label">Rango</div><div class="meta-item-value">{RANK_LABELS[law.rango] ?? capitalize(law.rango.replace(/_/g, ' '))}</div></div>
					<div><div class="meta-item-label">Estado</div><div class="meta-item-value">{capitalize(law.estado.replace(/_/g, ' '))}</div></div>
					<div><div class="meta-item-label">Publicación</div><div class="meta-item-value">{formatDate(law.fecha_publicacion)}</div></div>
					<div><div class="meta-item-label">Departamento</div><div class="meta-item-value">{law.departamento}</div></div>
				</div>
			</div>

			{materias.length > 0 && (
				<div class="section">
					<h3 class="section-heading">Categorías del BOE</h3>
					<div>
						{materias.map((m) => (
							<a href={`/?materia=${encodeURIComponent(m)}`} class="materia-tag">{m}</a>
						))}
					</div>
				</div>
			)}

			{notas.length > 0 && (
				<div class="section">
					<h3 class="section-heading">Notas del BOE</h3>
					{notas.map((nota) => (
						<p class="nota-item">{nota}</p>
					))}
				</div>
			)}

			{refsAnt.length > 0 && (
				<div class="section">
					<h3 class="section-heading">Leyes en las que se basa</h3>
					<ul class="ref-list">
						{refsAnt.map((ref) => (
							<li>
								{ref.texto.replace(/^[,\s]+/, '').replace(/[,\s]+$/, '')}
								{ref.norma && <> <a href={`/laws/${ref.norma}`}>{ref.norma}</a></>}
							</li>
						))}
					</ul>
				</div>
			)}

			{refsPost.length > 0 && (
				<div class="section">
					<h3 class="section-heading">Leyes que la modifican</h3>
					<ul class="ref-list">
						{refsPost.map((ref) => (
							<li>
								{ref.texto.replace(/^[,\s]+/, '').replace(/[,\s]+$/, '')}
								{ref.norma && <> <a href={`/laws/${ref.norma}`}>{ref.norma}</a></>}
							</li>
						))}
					</ul>
				</div>
			)}
		</div>

		<!-- Follow this law -->
		<div class="follow-card" id="follow-card">
			<div class="follow-icon">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
			</div>
			<div class="follow-content">
				<h3 class="follow-heading">¿Quieres saber cuándo cambia esta ley?</h3>
				<p class="follow-desc">Recibe un aviso por email cada vez que se publique una modificación.</p>
				<form class="follow-form" id="follow-form" data-norm-id={id}>
					<div class="follow-input-row">
						<input
							type="email"
							name="email"
							placeholder="Tu email"
							required
							class="follow-input"
							autocomplete="email"
						/>
						<button type="submit" class="follow-btn">Seguir esta ley</button>
					</div>
				</form>
				<p class="follow-msg" id="follow-msg" style="display: none;"></p>
			</div>
		</div>
	</div>

	<!-- Tab: Reformas (static) -->
	<div class="tab-panel" id="tab-reformas">
		{reforms.length <= 1 ? (
			<p style="color: var(--text-muted); font-size: 0.9375rem;">Esta ley no tiene modificaciones registradas desde su publicación.</p>
		) : (
			<ul class="timeline">
				{reforms.map((reform, i) => {
					const isOriginal = i === reforms.length - 1;
					const reformaUrl = !isOriginal ? `/reforma?id=${id}&date=${reform.fecha}` : null;
					return (
						<li class="timeline-item">
							<div class="timeline-dot"></div>
							<div class="timeline-date">{formatDate(reform.fecha)}</div>
							<div class="timeline-detail">
								{isOriginal ? 'Versión original' : `Reforma`}
								{' '}<span style="font-family:var(--font-mono);font-size:0.6875rem">{reform.fuente}</span>
							</div>
							{reformaUrl && <a href={reformaUrl} class="timeline-link">Ver qué cambió &rarr;</a>}
						</li>
					);
				})}
			</ul>
		)}
	</div>

	<!-- Tab: Texto completo (static, pre-rendered from Markdown) -->
	<div class="tab-panel" id="tab-texto">
		<div class="law-content" set:html={htmlContent} />
	</div>

	<!-- Tab switching (no API needed) -->
	<script is:inline>
		document.querySelectorAll('.tab').forEach(function(tab) {
			tab.addEventListener('click', function() {
				document.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('active'); });
				document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.remove('active'); });
				tab.classList.add('active');
				document.getElementById('tab-' + tab.dataset.tab)?.classList.add('active');
			});
		});
		// View toggle: citizen (default) vs technical details
		var toggleBtn = document.getElementById('view-toggle');
		var techDetails = document.getElementById('technical-details');
		if (toggleBtn && techDetails) {
			toggleBtn.addEventListener('click', function() {
				var isOpen = techDetails.style.display !== 'none';
				techDetails.style.display = isOpen ? 'none' : 'block';
				toggleBtn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
				toggleBtn.textContent = isOpen ? 'Ver información completa \u25B8' : 'Ocultar información completa \u25BE';
			});
		}
	</script>

	<!-- Follow form handler -->
	<script is:inline define:vars={{ apiBase: import.meta.env.API_URL ?? "https://api.leyabierta.es" }}>
		(function() {
			var form = document.getElementById('follow-form');
			if (!form) return;

			form.addEventListener('submit', function(e) {
				e.preventDefault();
				var emailInput = form.querySelector('input[name="email"]');
				var btn = form.querySelector('button[type="submit"]');
				var msg = document.getElementById('follow-msg');
				var normId = form.dataset.normId;
				var email = emailInput.value.trim();

				if (!email || !normId) return;

				btn.disabled = true;
				btn.textContent = 'Enviando...';
				msg.style.display = 'none';

				fetch(apiBase + '/v1/alerts/follow', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ email: email, normId: normId })
				})
				.then(function(res) { return res.json(); })
				.then(function(data) {
					if (data.ok) {
						msg.textContent = 'Te hemos enviado un email de confirmación. Revisa tu bandeja de entrada.';
						msg.className = 'follow-msg success';
						form.style.display = 'none';
					} else {
						msg.textContent = data.error || 'Ocurrió un error. Inténtalo de nuevo.';
						msg.className = 'follow-msg error';
						btn.disabled = false;
						btn.textContent = 'Seguir esta ley';
					}
					msg.style.display = 'block';
				})
				.catch(function() {
					msg.textContent = 'Error de conexión. Inténtalo de nuevo.';
					msg.className = 'follow-msg error';
					msg.style.display = 'block';
					btn.disabled = false;
					btn.textContent = 'Seguir esta ley';
				});
			});
		})();
	</script>

	<!-- JSON-LD -->
	<script
		type="application/ld+json"
		set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Legislation",
			name: law.titulo,
			datePublished: law.fecha_publicacion,
			legislationDate: law.fecha_publicacion,
			legislationType: RANK_LABELS[law.rango] ?? law.rango,
			inLanguage: "es",
			url: `https://leyabierta.es/laws/${id}`,
			publisher: {
				"@type": "Organization",
				name: "Agencia Estatal BOE",
				url: "https://www.boe.es",
			},
		})}
	/>
</Base>
