---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
	const laws = await getCollection("laws");
	return laws.map((entry) => ({
		params: { id: entry.data.identificador },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { id } = Astro.params;
const law = entry.data;
const { Content } = await render(entry);

const RANK_LABELS: Record<string, string> = {
	constitucion: "Constitución",
	ley_organica: "Ley Orgánica",
	ley: "Ley",
	real_decreto_ley: "Real Decreto-ley",
	real_decreto_legislativo: "Real Decreto Legislativo",
	real_decreto: "Real Decreto",
	orden: "Orden",
	decreto: "Decreto",
	circular: "Circular",
	resolucion: "Resolución",
	acuerdo_internacional: "Acuerdo Internacional",
};

const MONTHS = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
function formatDate(iso: string): string {
	if (!iso) return '';
	const [y, m, d] = iso.split('-');
	return `${parseInt(d!, 10)} de ${MONTHS[parseInt(m!, 10) - 1]} de ${y}`;
}
---

<Base
	title={law.titulo}
	description={`${RANK_LABELS[law.rango] ?? law.rango} · ${law.estado} · Publicada ${law.fecha_publicacion} · ${law.departamento}`}
	ogTitle={law.titulo}
	ogType="article"
	canonicalUrl={`/laws/${id}`}
>
	<style>
		.back-link { font-size: 0.8125rem; color: var(--text-muted); }
		.back-link:hover { color: var(--text-secondary); }

		.law-header {
			display: flex;
			justify-content: space-between;
			align-items: flex-start;
			gap: 1rem;
			margin: 0.75rem 0 0.5rem;
		}
		.law-title {
			font-family: var(--font-serif);
			font-size: 1.375rem;
			font-weight: 700;
			line-height: 1.35;
			letter-spacing: -0.01em;
			flex: 1;
		}
		.boe-btn {
			display: inline-flex;
			align-items: center;
			gap: 0.375rem;
			padding: 0.4rem 0.875rem;
			border: 1.5px solid var(--border);
			border-radius: 6px;
			font-size: 0.8125rem;
			font-weight: 600;
			color: var(--text-secondary);
			background: var(--surface);
			white-space: nowrap;
			flex-shrink: 0;
			transition: all 0.15s;
		}
		.boe-btn:hover { border-color: var(--accent); color: var(--accent); text-decoration: none; }

		.meta-row {
			display: flex;
			flex-wrap: wrap;
			gap: 0.5rem;
			align-items: center;
			font-size: 0.8125rem;
			color: var(--text-muted);
			margin-bottom: 1.5rem;
			line-height: 1.4;
		}
		.meta-sep { color: var(--border); }
		.meta-item { display: inline-flex; align-items: center; gap: 0.3rem; }
		.meta-item svg { flex-shrink: 0; opacity: 0.5; }
		.meta-id { font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted); position: relative; top: 0.5px; }

		/* ── Tabs ── */
		.tabs { display: flex; gap: 0; border-bottom: 1px solid var(--border); }
		.tab {
			padding: 0.5rem 1rem;
			font-size: 0.8125rem;
			font-weight: 500;
			color: var(--text-muted);
			cursor: pointer;
			border: none;
			background: none;
			border-bottom: 2px solid transparent;
			margin-bottom: -1px;
			font-family: var(--font-sans);
		}
		.tab:hover { color: var(--text); }
		.tab.active { color: var(--accent); border-bottom-color: var(--accent); }
		.tab-badge {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			min-width: 1.25rem;
			height: 1.25rem;
			padding: 0 0.3rem;
			border-radius: 100px;
			background: var(--accent-bg);
			color: var(--accent);
			font-size: 0.6875rem;
			font-weight: 600;
			margin-left: 0.375rem;
		}
		.tab-panel { display: none; padding-top: 1.5rem; }
		.tab-panel.active { display: block; }

		/* ── Content ── */
		.law-content {
			font-family: var(--font-serif);
			line-height: 1.8;
			font-size: 0.9375rem;
		}
		.law-content :global(h1) { font-size: 1.25rem; font-weight: 700; margin: 1.5rem 0 0.75rem; }
		.law-content :global(h2) { font-size: 1rem; font-weight: 600; color: var(--accent); margin: 1.25rem 0 0.5rem; font-family: var(--font-sans); }
		.law-content :global(h3) { font-size: 0.9375rem; font-weight: 600; margin: 1rem 0 0.5rem; }
		.law-content :global(p) { margin-bottom: 0.75rem; }

		/* ── Loading states ── */
		.loading { text-align: center; padding: 2rem; color: var(--text-muted); font-size: 0.875rem; }
		.loading-spinner { display: inline-block; width: 1.25rem; height: 1.25rem; border: 2px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.6s linear infinite; margin-right: 0.5rem; vertical-align: middle; }
		@keyframes spin { to { transform: rotate(360deg); } }

		@media (max-width: 640px) {
			.law-header { flex-direction: column; }
		}
	</style>

	<!-- Styles for JS-injected tab content (must be global) -->
	<style is:global>
		.quick-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 0.75rem; margin-bottom: 1.5rem; }
		.stat-card { display: flex; align-items: center; gap: 0.625rem; padding: 0.875rem 1rem; background: var(--surface); border: 1px solid var(--border-light); border-radius: 10px; }
		.stat-value { font-variant-numeric: tabular-nums; font-size: 1.25rem; font-weight: 700; color: var(--accent); line-height: 1.2; }
		.stat-label { font-size: 0.6875rem; color: var(--text-muted); }
		.timeline { list-style: none; padding: 0; }
		.timeline-item { position: relative; padding: 0 0 1rem 1.5rem; }
		.timeline-item::before { content: ""; position: absolute; left: 0.28rem; top: 0.5rem; bottom: -0.25rem; width: 1px; background: var(--border); }
		.timeline-item:last-child::before { display: none; }
		.timeline-dot { position: absolute; left: 0; top: 0.35rem; width: 0.625rem; height: 0.625rem; border-radius: 50%; border: 2px solid var(--border); background: var(--bg); }
		.timeline-item:last-child .timeline-dot { border-color: var(--accent); background: var(--accent); }
		.timeline-date { font-weight: 600; font-size: 0.8125rem; }
		.timeline-detail { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.125rem; }
		.timeline-link { font-size: 0.75rem; margin-top: 0.25rem; display: inline-block; }
		.section { margin-bottom: 2rem; }
		.section-heading { font-size: 1.0625rem; font-weight: 600; margin-bottom: 0.75rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border-light); }
		.materia-tag { display: inline-block; padding: 0.25rem 0.75rem; border: 1px solid var(--border); border-radius: 100px; font-size: 0.8125rem; color: var(--text-secondary); margin: 0.125rem 0.25rem 0.125rem 0; transition: all 0.15s; }
		.materia-tag:hover { background: var(--accent-bg); color: var(--accent); border-color: var(--accent); text-decoration: none; }
		.ref-list { list-style: disc; padding-left: 1.5rem; margin: 0; }
		.ref-list li { font-size: 0.875rem; line-height: 1.65; color: var(--text-secondary); margin-bottom: 0.375rem; }
		.ref-list a { font-family: var(--font-mono); font-size: 0.8125rem; }
		.nota-item { font-size: 0.8125rem; color: var(--text-secondary); line-height: 1.6; margin-bottom: 0.375rem; }
		.card { background: var(--surface); border: 1px solid var(--border-light); border-radius: 10px; padding: 1.25rem 1.5rem; margin-bottom: 1rem; }
		.card-heading { font-size: 1rem; font-weight: 600; margin-bottom: 0.75rem; }
		.meta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; font-size: 0.875rem; }
		.meta-item-label { color: var(--text-muted); font-size: 0.8125rem; margin-bottom: 0.125rem; }
		.meta-item-value { color: var(--text); font-weight: 500; }
		@media (max-width: 640px) {
			.meta-grid { grid-template-columns: 1fr; }
			.quick-stats { grid-template-columns: repeat(2, 1fr); }
		}
	</style>

	<a href="/" class="back-link">&larr; Volver</a>

	<div class="law-header">
		<div>
			<div style="display: flex; gap: 0.375rem; margin-bottom: 0.375rem;">
				<span class={`badge badge-${law.estado}`}>{law.estado}</span>
				<span class="badge" style="background: var(--accent-bg); color: var(--accent);">{RANK_LABELS[law.rango] ?? law.rango}</span>
			</div>
			<h1 class="law-title">{law.titulo}</h1>
		</div>
		<a href={`https://www.boe.es/buscar/act.php?id=${law.identificador}`} target="_blank" rel="noopener" class="boe-btn">
			<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
			Ver en BOE
		</a>
	</div>

	<div class="meta-row">
		<span class="meta-item">
			<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
			{formatDate(law.fecha_publicacion)}
		</span>
		{law.ultima_actualizacion && law.ultima_actualizacion !== law.fecha_publicacion && (
			<>
				<span class="meta-sep">&middot;</span>
				<span class="meta-item">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M12 7v5l4 2"/></svg>
					{formatDate(law.ultima_actualizacion)}
				</span>
			</>
		)}
		<span class="meta-sep">&middot;</span>
		<span class="meta-item">
			<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" x2="21" y1="22" y2="22"/><line x1="6" x2="6" y1="18" y2="11"/><line x1="10" x2="10" y1="18" y2="11"/><line x1="14" x2="14" y1="18" y2="11"/><line x1="18" x2="18" y1="18" y2="11"/><polygon points="12 2 20 7 4 7"/></svg>
			{law.departamento}
		</span>
		<span class="meta-sep">&middot;</span>
		<span class="meta-item meta-id">{id}</span>
	</div>

	<!-- Tabs -->
	<div class="tabs">
		<button class="tab active" data-tab="resumen">Resumen</button>
		<button class="tab" data-tab="reformas">Historial de cambios</button>
		<button class="tab" data-tab="texto">Texto completo</button>
	</div>

	<!-- Tab: Resumen (default, loaded client-side from API) -->
	<div class="tab-panel active" id="tab-resumen">
		<div class="loading" id="resumen-loading">
			<span class="loading-spinner"></span> Cargando resumen...
		</div>
		<div id="resumen-content" style="display:none;"></div>
	</div>

	<!-- Tab: Reformas (loaded client-side from API) -->
	<div class="tab-panel" id="tab-reformas">
		<div class="loading" id="reformas-loading">
			<span class="loading-spinner"></span> Cargando historial...
		</div>
		<div id="reformas-content" style="display:none;"></div>
	</div>

	<!-- Tab: Texto completo (static, pre-rendered from Markdown) -->
	<div class="tab-panel" id="tab-texto">
		<div class="law-content">
			<Content />
		</div>
	</div>

	<script is:inline define:vars={{ lawId: id }}>
		const API = document.documentElement.dataset.api;
		const loaded = { resumen: false, reformas: false };

		// Tab switching
		document.querySelectorAll('.tab').forEach(tab => {
			tab.addEventListener('click', () => {
				document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
				document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
				tab.classList.add('active');
				document.getElementById('tab-' + tab.dataset.tab)?.classList.add('active');

				// Lazy load data
				if (tab.dataset.tab === 'resumen' && !loaded.resumen) loadResumen();
				if (tab.dataset.tab === 'reformas' && !loaded.reformas) loadReformas();
			});
		});

		async function loadResumen() {
			loaded.resumen = true;
			try {
				const [lawRes, analisisRes] = await Promise.all([
					fetch(`${API}/v1/laws/${lawId}`),
					fetch(`${API}/v1/laws/${lawId}/analisis`),
				]);
				const law = await lawRes.json();
				const analisis = await analisisRes.json();

				var RANKS = {"constitucion":"Constitución","ley_organica":"Ley Orgánica","ley":"Ley","real_decreto_ley":"Real Decreto-ley","real_decreto_legislativo":"RD Legislativo","real_decreto":"Real Decreto","orden":"Orden","decreto":"Decreto","circular":"Circular","resolucion":"Resolución","acuerdo_internacional":"Acuerdo Internacional","instruccion":"Instrucción","reglamento":"Reglamento"};
				function capitalize(s) { return s ? s.charAt(0).toUpperCase() + s.slice(1) : ''; }
				function formatDate(iso) {
					if (!iso) return '';
					var months = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
					var parts = iso.split('-');
					return parseInt(parts[2],10) + ' de ' + months[parseInt(parts[1],10)-1] + ' de ' + parts[0];
				}

				let html = '<div class="quick-stats">';
				html += `<div class="stat-card"><div><div class="stat-value">${law.blocks?.length ?? 0}</div><div class="stat-label">Artículos</div></div></div>`;
				html += `<div class="stat-card"><div><div class="stat-value">${law.reforms?.length ?? 0}</div><div class="stat-label">Versiones</div></div></div>`;
				if (analisis.materias?.length > 0) {
					html += `<div class="stat-card"><div><div class="stat-value">${analisis.materias.length}</div><div class="stat-label">Temas</div></div></div>`;
				}
				html += '</div>';

				// General info card
				html += '<div class="card"><h3 class="card-heading">Información general</h3><div class="meta-grid">';
				html += `<div><div class="meta-item-label">Rango</div><div class="meta-item-value">${RANKS[law.rank] || capitalize(law.rank?.replace(/_/g,' ')) || ''}</div></div>`;
				html += `<div><div class="meta-item-label">Estado</div><div class="meta-item-value">${capitalize(law.status)}</div></div>`;
				html += `<div><div class="meta-item-label">Publicación</div><div class="meta-item-value">${formatDate(law.published_at)}</div></div>`;
				html += `<div><div class="meta-item-label">Departamento</div><div class="meta-item-value">${law.department ?? ''}</div></div>`;
				html += '</div></div>';

				// Materias
				if (analisis.materias?.length > 0) {
					html += '<div class="section"><h3 class="section-heading">Temas</h3><div>';
					for (const m of analisis.materias) {
						html += `<a href="/?materia=${encodeURIComponent(m)}" class="materia-tag">${m}</a>`;
					}
					html += '</div></div>';
				}

				// Notas
				if (analisis.notas?.length > 0) {
					html += '<div class="section"><h3 class="section-heading">Notas</h3>';
					for (const nota of analisis.notas) {
						html += `<p class="nota-item">${nota}</p>`;
					}
					html += '</div>';
				}

				// Referencias
				if (analisis.referencias?.anteriores?.length > 0) {
					html += '<div class="section"><h3 class="section-heading">Esta ley se basa en</h3><ul class="ref-list">';
					for (const ref of analisis.referencias.anteriores) {
						const text = (ref.text || '').replace(/^[,\s]+/, '').replace(/[,\s]+$/, '');
						html += `<li>${text} ${ref.normId ? `<a href="/laws/${ref.normId}">${ref.normId}</a>` : ''}</li>`;
					}
					html += '</ul></div>';
				}
				if (analisis.referencias?.posteriores?.length > 0) {
					html += '<div class="section"><h3 class="section-heading">Leyes que modifican esta</h3><ul class="ref-list">';
					for (const ref of analisis.referencias.posteriores) {
						const text = (ref.text || '').replace(/^[,\s]+/, '').replace(/[,\s]+$/, '');
						html += `<li>${text} ${ref.normId ? `<a href="/laws/${ref.normId}">${ref.normId}</a>` : ''}</li>`;
					}
					html += '</ul></div>';
				}

				document.getElementById('resumen-loading').style.display = 'none';
				document.getElementById('resumen-content').innerHTML = html;
				document.getElementById('resumen-content').style.display = 'block';
			} catch {
				document.getElementById('resumen-loading').innerHTML = 'No se pudo cargar el resumen. La API no está disponible.';
			}
		}

		async function loadReformas() {
			loaded.reformas = true;
			try {
				const res = await fetch(`${API}/v1/laws/${lawId}`);
				const law = await res.json();

				if (!law.reforms || law.reforms.length <= 1) {
					document.getElementById('reformas-loading').innerHTML = 'Esta ley no tiene reformas registradas.';
					return;
				}

				// Update tab badge
				const reformTab = document.querySelector('[data-tab="reformas"]');
				if (reformTab && !reformTab.querySelector('.tab-badge')) {
					reformTab.innerHTML += ` <span class="tab-badge">${law.reforms.length}</span>`;
				}

				let html = '<ul class="timeline">';
				for (let i = 0; i < law.reforms.length; i++) {
					const reform = law.reforms[i];
					const isFirst = i === 0;
					const prevDate = i > 0 ? law.reforms[i - 1].date : null;
					const diffUrl = prevDate ? `/diff?id=${lawId}&from=${prevDate}&to=${reform.date}` : null;

					html += '<li class="timeline-item">';
					html += '<div class="timeline-dot"></div>';
					html += `<div class="timeline-date">${reform.date}</div>`;
					html += `<div class="timeline-detail">${isFirst ? 'Versión original' : `${reform.affected_blocks?.length ?? 0} artículos modificados`} <span style="font-family:var(--font-mono);font-size:0.6875rem">${reform.source_id ?? ''}</span></div>`;
					if (diffUrl) html += `<a href="${diffUrl}" class="timeline-link">Ver cambios &rarr;</a>`;
					html += '</li>';
				}
				html += '</ul>';

				document.getElementById('reformas-loading').style.display = 'none';
				document.getElementById('reformas-content').innerHTML = html;
				document.getElementById('reformas-content').style.display = 'block';
			} catch {
				document.getElementById('reformas-loading').innerHTML = 'No se pudo cargar el historial. La API no está disponible.';
			}
		}

		// Auto-load resumen (default tab) + prefetch reform count for badge
		loadResumen();
		fetch(API + '/v1/laws/' + lawId).then(function (r) { return r.json(); }).then(function (law) {
			if (law.reforms && law.reforms.length > 1) {
				var reformTab = document.querySelector('[data-tab="reformas"]');
				if (reformTab) reformTab.innerHTML = 'Historial de cambios <span class="tab-badge">' + law.reforms.length + '</span>';
			}
		}).catch(function () {});
	</script>

	<!-- JSON-LD -->
	<script
		type="application/ld+json"
		set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Legislation",
			name: law.titulo,
			datePublished: law.fecha_publicacion,
			legislationDate: law.fecha_publicacion,
			legislationType: RANK_LABELS[law.rango] ?? law.rango,
			inLanguage: "es",
			url: `https://leyabierta.es/laws/${id}`,
			publisher: {
				"@type": "Organization",
				name: "Agencia Estatal BOE",
				url: "https://www.boe.es",
			},
		})}
	/>
</Base>
