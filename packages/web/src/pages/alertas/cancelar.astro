---
import Base from "../../layouts/Base.astro";
---

<Base
	title="Cancelar suscripcion"
	description="Cancela tu suscripcion a las alertas legislativas de Ley Abierta."
	canonicalUrl="/alertas/cancelar"
>
	<style>
		.cancel-page { max-width: 28rem; margin: 4rem auto; text-align: center; }
		.cancel-icon { font-size: 3rem; margin-bottom: 1rem; }
		.cancel-page h1 { font-family: var(--font-serif); font-size: 1.5rem; font-weight: 700; margin-bottom: 0.75rem; }
		.cancel-page p { color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; }
		.error-msg { color: var(--danger); background: var(--danger-bg); padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; }
		.loading { color: var(--text-muted); }
	</style>

	<div class="cancel-page" id="cancel-content">
		<div class="loading">Procesando cancelacion...</div>
	</div>

	<script is:inline>
		(function () {
			var API = document.documentElement.dataset.api;
			var token = new URLSearchParams(window.location.search).get("token");
			var el = document.getElementById("cancel-content");

			if (!token) {
				el.innerHTML = '<div class="cancel-icon">&#10007;</div><h1>Enlace no valido</h1><div class="error-msg">Falta el token.</div><a href="/alertas" class="btn">Volver a alertas</a>';
				return;
			}

			fetch(API + "/v1/alerts/unsubscribe/" + token)
				.then(function (r) { return r.json(); })
				.then(function (data) {
					if (data.ok) {
						el.innerHTML = '<div class="cancel-icon">&#128075;</div><h1>Suscripcion cancelada</h1><p>Ya no recibiras mas emails. Si cambias de opinion, siempre puedes volver a suscribirte.</p><a href="/alertas" class="btn btn-primary">Volver a alertas</a>';
					} else {
						el.innerHTML = '<div class="cancel-icon">&#10007;</div><h1>No se pudo cancelar</h1><div class="error-msg">' + (data.error || "Enlace no valido.") + '</div><a href="/alertas" class="btn">Volver a alertas</a>';
					}
				})
				.catch(function () {
					el.innerHTML = '<div class="cancel-icon">&#10007;</div><h1>Error</h1><div class="error-msg">Error al cancelar. Intentalo de nuevo.</div><a href="/alertas" class="btn">Volver a alertas</a>';
				});
		})();
	</script>
</Base>
