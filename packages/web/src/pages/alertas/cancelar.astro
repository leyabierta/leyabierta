---
import Base from "../../layouts/Base.astro";
import { cancelSubscription } from "../../lib/api";

const token = Astro.url.searchParams.get("token") ?? "";

let success = false;
let errorMsg = "";

if (token) {
	try {
		const result = await cancelSubscription(token);
		success = !!result.ok;
		if (!success) errorMsg = result.error ?? "Enlace no valido.";
	} catch {
		errorMsg = "Error al cancelar. Intentalo de nuevo.";
	}
} else {
	errorMsg = "Enlace no valido.";
}
---

<Base
	title="Cancelar suscripcion"
	description="Cancela tu suscripcion a las alertas legislativas de Ley Abierta."
	canonicalUrl="/alertas/cancelar"
>
	<style>
		.cancel-page {
			max-width: 28rem;
			margin: 4rem auto;
			text-align: center;
		}
		.cancel-icon {
			font-size: 3rem;
			margin-bottom: 1rem;
		}
		.cancel-page h1 {
			font-family: var(--font-serif);
			font-size: 1.5rem;
			font-weight: 700;
			margin-bottom: 0.75rem;
		}
		.cancel-page p {
			color: var(--text-secondary);
			line-height: 1.7;
			margin-bottom: 1.5rem;
		}
		.error-msg {
			color: var(--danger);
			background: var(--danger-bg);
			padding: 1rem;
			border-radius: 8px;
			margin-bottom: 1.5rem;
		}
	</style>

	<div class="cancel-page">
		{success ? (
			<>
				<div class="cancel-icon">&#128075;</div>
				<h1>Suscripcion cancelada</h1>
				<p>
					Ya no recibiras mas emails de alertas legislativas.
					Si cambias de opinion, siempre puedes volver a suscribirte.
				</p>
				<a href="/alertas" class="btn btn-primary">Volver a alertas</a>
			</>
		) : (
			<>
				<div class="cancel-icon">&#10007;</div>
				<h1>No se pudo cancelar</h1>
				<div class="error-msg">{errorMsg}</div>
				<a href="/alertas" class="btn">Volver a alertas</a>
			</>
		)}
	</div>
</Base>
