---
import Base from "../../layouts/Base.astro";
import { getDigestProfiles, getProfileDigests } from "../../lib/api";

export async function getStaticPaths() {
	const { data } = await getDigestProfiles();
	console.log(`[resumenes] Generated ${data.length} digest profile pages`);
	return data.map((p) => ({ params: { perfil: p.profile_id } }));
}

const { perfil } = Astro.params;

let profile: { id: string; name: string; icon: string; description: string } | null = null;
let digests: Array<{ week: string; summary: string; generated_at: string; reform_count: number }> = [];

try {
	const result = await getProfileDigests(perfil!);
	profile = result.profile;
	digests = result.data;
} catch {
	// API not available
}

const displayProfile = profile ?? { id: perfil!, name: perfil!, icon: "", description: "" };

const MONTHS = ["ene", "feb", "mar", "abr", "may", "jun", "jul", "ago", "sep", "oct", "nov", "dic"];

function weekToDateRange(w: string): string {
	const match = w.match(/^(\d{4})-W(\d+)$/);
	if (!match) return w;
	const year = parseInt(match[1], 10);
	const weekNum = parseInt(match[2], 10);
	const jan4 = new Date(year, 0, 4);
	const dayOfWeek = jan4.getDay() || 7;
	const monday = new Date(jan4);
	monday.setDate(jan4.getDate() - dayOfWeek + 1 + (weekNum - 1) * 7);
	const sunday = new Date(monday);
	sunday.setDate(monday.getDate() + 6);
	const d1 = monday.getDate();
	const m1 = MONTHS[monday.getMonth()];
	const d2 = sunday.getDate();
	const m2 = MONTHS[sunday.getMonth()];
	if (m1 === m2) return `${d1}–${d2} ${m1} ${year}`;
	return `${d1} ${m1} – ${d2} ${m2} ${year}`;
}

const digestsForDisplay = digests.map((d) => ({
	...d,
	dateRange: weekToDateRange(d.week),
}));
---

<Base
	title={`Resúmenes — ${displayProfile.name}`}
	description={`Histórico de resúmenes semanales del perfil ${displayProfile.name}. Cambios legislativos explicados en lenguaje ciudadano.`}
	ogTitle={`Resúmenes ${displayProfile.name} — Ley Abierta`}
	canonicalUrl={`/resumenes/${perfil}`}
>
	<style>
		.back-link {
			display: inline-flex;
			align-items: center;
			gap: 0.3rem;
			font-size: 0.8125rem;
			color: var(--text-muted);
			margin-bottom: 1.5rem;
		}
		.back-link:hover { color: var(--accent); text-decoration: none; }

		.profile-header {
			margin-bottom: 2rem;
		}
		.profile-header .top-row {
			display: flex;
			align-items: center;
			gap: 0.75rem;
			margin-bottom: 0.375rem;
		}
		.profile-header .icon {
			font-size: 2rem;
		}
		.profile-header h1 {
			font-family: var(--font-serif);
			font-size: 1.75rem;
			font-weight: 700;
			line-height: 1.2;
		}
		.profile-header .desc {
			color: var(--text-secondary);
			font-size: 0.9375rem;
			line-height: 1.6;
		}

		.digest-list {
			list-style: none;
			padding: 0;
		}
		.digest-item {
			border-bottom: 1px solid var(--border-light);
		}
		.digest-item:first-child {
			border-top: 1px solid var(--border-light);
		}
		.digest-item a {
			display: block;
			padding: 1.125rem 0;
			text-decoration: none;
			color: inherit;
			transition: background 0.15s;
		}
		.digest-item a:hover {
			text-decoration: none;
		}
		.digest-item a:hover .digest-title {
			color: var(--accent);
		}
		.digest-top {
			display: flex;
			align-items: baseline;
			gap: 0.75rem;
			margin-bottom: 0.375rem;
		}
		.digest-title {
			font-family: var(--font-serif);
			font-weight: 600;
			font-size: 1rem;
			transition: color 0.15s;
		}
		.digest-date {
			font-size: 0.8125rem;
			color: var(--text-muted);
		}
		.digest-count {
			font-size: 0.75rem;
			color: var(--accent);
			font-weight: 500;
			white-space: nowrap;
		}
		.digest-summary {
			font-size: 0.875rem;
			color: var(--text-secondary);
			line-height: 1.6;
			display: -webkit-box;
			-webkit-line-clamp: 2;
			-webkit-box-orient: vertical;
			overflow: hidden;
		}

		.empty-state {
			text-align: center;
			padding: 3rem 1rem;
			color: var(--text-muted);
		}
		.empty-state p {
			font-size: 0.9375rem;
			line-height: 1.6;
			margin-bottom: 1.5rem;
		}
	</style>

	<a href="/resumenes" class="back-link">&#8592; Todos los perfiles</a>

	<div class="profile-header">
		<div class="top-row">
			<div class="icon">{displayProfile.icon}</div>
			<h1>{displayProfile.name}</h1>
		</div>
		<p class="desc">{displayProfile.description}</p>
	</div>

	{digestsForDisplay.length > 0 ? (
		<ul class="digest-list">
			{digestsForDisplay.map((d) => (
				<li class="digest-item">
					<a href={`/resumenes/${perfil}/${d.week}`}>
						<div class="digest-top">
							<span class="digest-title">{d.dateRange}</span>
							<span class="digest-count">{d.reform_count} cambio{d.reform_count === 1 ? "" : "s"}</span>
						</div>
						{d.summary && <p class="digest-summary">{d.summary}</p>}
					</a>
				</li>
			))}
		</ul>
	) : (
		<div class="empty-state">
			<p>Aún no hay resúmenes para este perfil. Se generan cada semana.</p>
		</div>
	)}
</Base>
