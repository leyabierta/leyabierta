---
import Base from "../../layouts/Base.astro";
import { PROFILES } from "../../../../api/src/data/profiles";
import fs from "node:fs";
import path from "node:path";

const profiles = PROFILES.map(({ id, name, description, icon }) => ({ id, name, description, icon }));

// Scan data/digests/ YAML files to find digest counts and latest week per profile
const digestDir = path.join(process.cwd(), "..", "..", "data", "digests");

function discoverDigestsForProfile(profileId: string): string[] {
	const weeks: string[] = [];
	try {
		for (const year of fs.readdirSync(digestDir)) {
			const yearDir = path.join(digestDir, year);
			if (!fs.statSync(yearDir).isDirectory()) continue;
			for (const weekFolder of fs.readdirSync(yearDir)) {
				const weekPath = path.join(yearDir, weekFolder);
				if (!fs.statSync(weekPath).isDirectory()) continue;
				const yamlFile = path.join(weekPath, `${profileId}.yaml`);
				if (fs.existsSync(yamlFile)) {
					weeks.push(`${year}-${weekFolder}`);
				}
			}
		}
	} catch {
		// No digests directory yet
	}
	return weeks.sort().reverse();
}

const profilesWithData = profiles.map((p) => {
	const weeks = discoverDigestsForProfile(p.id);
	return {
		...p,
		latestWeek: weeks[0] ?? null,
		digestCount: weeks.length,
	};
});
---

<Base
	title="Resumenes semanales"
	description="Resumenes semanales de cambios legislativos por perfil profesional. Escritos en lenguaje ciudadano."
	ogTitle="Resumenes — Ley Abierta"
	canonicalUrl="/resumenes"
>
	<style>
		.hero { text-align: center; padding: 2.5rem 0 2rem; }
		.hero h1 {
			font-family: var(--font-serif);
			font-size: 2rem;
			font-weight: 700;
			line-height: 1.15;
			letter-spacing: -0.02em;
		}
		.hero-sub {
			color: var(--text-secondary);
			font-size: 1rem;
			margin-top: 0.75rem;
			max-width: 34rem;
			margin-left: auto;
			margin-right: auto;
			line-height: 1.7;
		}

		.profiles-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
			gap: 1rem;
			margin-bottom: 2rem;
		}
		.profile-card {
			border: 1.5px solid var(--border-light);
			border-radius: 10px;
			padding: 1.25rem;
			transition: all 0.15s;
			background: var(--surface);
			text-decoration: none;
			color: inherit;
			display: block;
		}
		.profile-card:hover {
			border-color: var(--accent);
			background: var(--accent-faint);
			text-decoration: none;
		}
		.profile-icon {
			font-size: 1.75rem;
			margin-bottom: 0.5rem;
		}
		.profile-name {
			font-family: var(--font-serif);
			font-weight: 600;
			font-size: 1rem;
			margin-bottom: 0.25rem;
		}
		.profile-desc {
			font-size: 0.8125rem;
			color: var(--text-muted);
			line-height: 1.5;
		}
		.profile-meta {
			font-size: 0.75rem;
			color: var(--text-muted);
			margin-top: 0.75rem;
			padding-top: 0.625rem;
			border-top: 1px solid var(--border-light);
		}
		.profile-meta span { color: var(--accent); font-weight: 500; }
		.no-digests {
			color: var(--text-muted);
			font-style: italic;
		}

		.cta-section {
			margin-top: 2rem;
			padding: 1.5rem;
			background: var(--accent-faint);
			border-radius: 10px;
			text-align: center;
		}
		.cta-section p {
			color: var(--text-secondary);
			font-size: 0.9375rem;
			line-height: 1.6;
			margin-bottom: 1rem;
		}

		@media (max-width: 640px) {
			.profiles-grid { grid-template-columns: 1fr 1fr; }
		}
	</style>

	<section class="hero">
		<h1>Resumenes semanales</h1>
		<p class="hero-sub">
			Cada semana, un resumen de los cambios legislativos que importan,
			escrito en lenguaje ciudadano. Elige tu perfil y consulta el historico.
		</p>
	</section>

	<div class="profiles-grid">
		{profilesWithData.map((p) => (
			p.digestCount > 0 ? (
				<a href={`/resumenes/${p.id}/`} class="profile-card">
					<div class="profile-icon">{p.icon}</div>
					<div class="profile-name">{p.name}</div>
					<div class="profile-desc">{p.description}</div>
					<div class="profile-meta">
						<span>{p.digestCount} resumen{p.digestCount === 1 ? "" : "es"}</span> · Ultimo: {p.latestWeek}
					</div>
				</a>
			) : (
				<div class="profile-card">
					<div class="profile-icon">{p.icon}</div>
					<div class="profile-name">{p.name}</div>
					<div class="profile-desc">{p.description}</div>
					<div class="profile-meta no-digests">Sin resumenes aun</div>
				</div>
			)
		))}
	</div>

	<div class="cta-section">
		<p>
			Quieres recibir estos resumenes directamente en tu email cada lunes?
		</p>
		<a href="/alertas" class="btn btn-primary">Suscribirme a alertas</a>
	</div>
</Base>
