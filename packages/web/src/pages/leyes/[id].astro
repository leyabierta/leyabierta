	<!-- Tab switching with URL hash persistence -->
	<script is:inline>
		(function() {
			var tabs = document.querySelectorAll('.tab');
			function activateTab(name) {
				tabs.forEach(function(t) { t.classList.remove('active'); });
				document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.remove('active'); });
				var target = document.querySelector('.tab[data-tab="' + name + '"]');
				var panel = document.getElementById('tab-' + name);
				if (target && panel) {
					target.classList.add('active');
					panel.classList.add('active');
				}
			}
			tabs.forEach(function(tab) {
				tab.addEventListener('click', function() {
					activateTab(tab.dataset.tab);
					history.replaceState(null, '', '#' + tab.dataset.tab);
				});
			});
			// Restore tab from URL hash on load
			var hash = location.hash.replace('#', '');
			if (hash && document.getElementById('tab-' + hash)) {
				activateTab(hash);
			} else if (hash && hash.indexOf('articulo-') === 0) {
				// Deep-link to an article: switch to texto tab and scroll to it
				activateTab('texto');
				var target = document.getElementById(hash);
				if (target) {
					setTimeout(function() {
						var top = target.getBoundingClientRect().top + window.scrollY - 80;
						window.scrollTo({ top: top, behavior: 'smooth' });
					}, 100);
				}
			}
		})();
	</script>

	<!-- Follow form handler -->
	<script is:inline define:vars={{ apiBase: import.meta.env.PUBLIC_API_URL ?? "https://api.leyabierta.es" }}>
		(function() {
			var form = document.getElementById('follow-form');
			if (!form) return;

			form.addEventListener('submit', function(e) {
				e.preventDefault();
				var emailInput = form.querySelector('input[name="email"]');
				var btn = form.querySelector('button[type="submit"]');
				var msg = document.getElementById('follow-msg');
				var normId = form.dataset.normId;
				var email = emailInput.value.trim();

				if (!email || !normId) return;

				btn.disabled = true;
				btn.textContent = 'Enviando...';
				msg.style.display = 'none';

				fetch(apiBase + '/v1/alerts/follow', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ email: email, normId: normId })
				})
				.then(function(res) { return res.json(); })
				.then(function(data) {
					if (data.ok) {
						msg.textContent = 'Te hemos enviado un email de confirmación. Revisa tu bandeja de entrada.';
						msg.className = 'follow-msg success';
						form.style.display = 'none';
					} else {
						msg.textContent = data.error || 'Ocurrió un error. Inténtalo de nuevo.';
						msg.className = 'follow-msg error';
						btn.disabled = false;
						btn.textContent = 'Seguir esta ley';
					}
					msg.style.display = 'block';
				})
				.catch(function() {
					msg.textContent = 'Error de conexión. Inténtalo de nuevo.';
					msg.className = 'follow-msg error';
					msg.style.display = 'block';
					btn.disabled = false;
					btn.textContent = 'Seguir esta ley';
				});
			});
		})();
	</script>

	<!-- Style rubric paragraphs (subtitles after structural headings) -->
	<script is:inline>
	(function() {
		var lawContent = document.querySelector('.law-content');
		if (!lawContent) return;
		// Find paragraphs that immediately follow h2/h3/h4 (structural headings)
		var headings = lawContent.querySelectorAll('h2, h3, h4');
		headings.forEach(function(h) {
			var next = h.nextElementSibling;
			// Skip <hr> elements between heading and rubric
			while (next && next.tagName === 'HR') { next = next.nextElementSibling; }
			if (!next || next.tagName !== 'P') return;
			var text = next.textContent.trim();
			// Rubrics: short text (< 120 chars), no period at end, not a sentence
			if (text.length > 0 && text.length < 120 && !text.endsWith('.') && !text.includes('. ')) {
				next.classList.add('law-rubric');
			}
		});
	})();
	</script>

	<!-- Build table of contents from headings in law content -->
	<script is:inline>
	(function() {
		var tocList = document.getElementById('toc-list');
		var lawContent = document.querySelector('.law-content');
		if (!tocList || !lawContent) return;

		var headings = lawContent.querySelectorAll('h2, h3, h4, h5, h6');
		if (headings.length === 0) {
			document.getElementById('toc')?.remove();
			return;
		}

		var frag = document.createDocumentFragment();
		var tocHeadings = [];
		headings.forEach(function(h, i) {
			if (!h.id) { h.id = 'sec-' + i; }
			var level = parseInt(h.tagName.charAt(1));
			var text = h.textContent.replace(/\s+/g, ' ').trim();
			if (text.length < 2) return;

			// For articles (h5/h6), shorten to just "Art. N"
			var label = text;
			if (level >= 5) {
				var artMatch = text.match(/^Art[ií]culo\s+(\d+[-\d]*)/i);
				if (artMatch) {
					label = 'Art. ' + artMatch[1];
				}
			}

			tocHeadings.push(h);
			var link = document.createElement('a');
			link.href = '#' + h.id;
			link.className = 'toc-item toc-level-' + level;
			link.textContent = label;
			link.title = text;
			link.addEventListener('click', function(e) {
				e.preventDefault();
				var top = h.getBoundingClientRect().top + window.scrollY - 80;
				window.scrollTo({ top: top, behavior: 'smooth' });
				history.replaceState(null, '', '#' + h.id);
			});
			frag.appendChild(link);
		});

		if (tocHeadings.length < 2) {
			document.getElementById('toc')?.remove();
			return;
		}

		tocList.appendChild(frag);

		// Highlight current section: find the last heading above the viewport top
		var tocItems = tocList.querySelectorAll('.toc-item');
		var ticking = false;
		function updateTocHighlight() {
			var scrollTop = window.scrollY + 100;
			var activeIdx = 0;
			for (var i = 0; i < tocHeadings.length; i++) {
				if (tocHeadings[i].offsetTop <= scrollTop) {
					activeIdx = i;
				} else {
					break;
				}
			}
			tocItems.forEach(function(item, j) {
				item.classList.toggle('toc-active', j === activeIdx);
			});
			// Scroll active TOC item into view within the sidebar
			var activeItem = tocItems[activeIdx];
			if (activeItem) {
				var tocEl = document.getElementById('toc');
				if (tocEl) {
					var itemTop = activeItem.offsetTop - tocEl.offsetTop;
					var tocScroll = tocEl.scrollTop;
					var tocHeight = tocEl.clientHeight;
					if (itemTop < tocScroll + 40 || itemTop > tocScroll + tocHeight - 40) {
						tocEl.scrollTop = itemTop - tocHeight / 3;
					}
				}
			}
			ticking = false;
		}
		window.addEventListener('scroll', function() {
			if (!ticking) {
				requestAnimationFrame(updateTocHighlight);
				ticking = true;
			}
		}, { passive: true });
		updateTocHighlight();
	})();
	</script>

	<!-- Omnibus topic → scroll to matching articles in full text -->
	<script is:inline>
	(function() {
		var topicCards = document.querySelectorAll('.omnibus-topic-card[data-block-ids]');
		if (!topicCards.length) return;

		topicCards.forEach(function(card) {
			card.addEventListener('click', function() {
				// Switch to "Texto completo" tab
				document.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('active'); });
				document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.remove('active'); });
				var textoTab = document.querySelector('.tab[data-tab="texto"]');
				var textoPanel = document.getElementById('tab-texto');
				if (textoTab) textoTab.classList.add('active');
				if (textoPanel) textoPanel.classList.add('active');

				// Parse block IDs and build match strings
				var blockIds = [];
				try { blockIds = JSON.parse(card.dataset.blockIds || '[]'); } catch(e) {}
				if (!blockIds.length) return;

				// Clear previous highlights
				document.querySelectorAll('.law-content .topic-highlight').forEach(function(el) {
					el.classList.remove('topic-highlight');
				});

				// Find and highlight matching headings
				var lawContent = document.querySelector('.law-content');
				if (!lawContent) return;
				var headings = lawContent.querySelectorAll('h2, h3, h4, h5, h6');
				var firstMatch = null;

				headings.forEach(function(h) {
					var text = h.textContent || '';
					var matched = blockIds.some(function(bid) {
						// block_id format: "articulo_1", "disposicion_adicional_primera" etc.
						// heading text: "Artículo 1. Naturaleza."
						var label = bid.replace(/_/g, ' ');
						return text.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "")
							.includes(label.normalize("NFD").replace(/[\u0300-\u036f]/g, ""));
					});
					if (matched) {
						h.classList.add('topic-highlight');
						if (!firstMatch) firstMatch = h;
					}
				});

				if (firstMatch) {
					setTimeout(function() {
						firstMatch.scrollIntoView({ behavior: 'smooth', block: 'center' });
					}, 100);
				}
			});
		});
	})();
	</script>

	<!-- Citizen article summaries as inline annotations -->
	<script is:inline define:vars={{ normId: id }}>
	(function() {
		var apiBase = document.documentElement.dataset.api || 'https://api.leyabierta.es';

		function norm(s) {
			return s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '')
				.replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, ' ').trim();
		}

		var injected = false;
		function loadAndInject() {
			if (injected) return;
			injected = true;

			fetch(apiBase + '/v1/laws/' + normId + '/summaries')
				.then(function(r) { return r.json(); })
				.then(function(summaries) {
					// summaries is { "Artículo 1. Título.": "Resumen...", ... }
					var entries = [];
					for (var title in summaries) {
						entries.push({ key: norm(title), summary: summaries[title] });
					}
					if (!entries.length) return;
					entries.sort(function(a, b) { return b.key.length - a.key.length; });

					var lawContent = document.querySelector('.law-content');
					if (!lawContent) return;

					lawContent.querySelectorAll('h5, h6').forEach(function(h) {
						var hNorm = norm(h.textContent || '');
						var matched = null;
						for (var i = 0; i < entries.length; i++) {
							if (hNorm.indexOf(entries[i].key) !== 0) continue;
							var next = hNorm.charAt(entries[i].key.length);
							if (!next || next === ' ' || next === '-') {
								matched = entries[i];
								break;
							}
						}
						if (!matched) return;

						var marker = document.createElement('button');
						marker.className = 'article-annotation-marker';
						marker.type = 'button';
						marker.setAttribute('aria-label', 'Ver resumen ciudadano');
						marker.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>';

						var tip = document.createElement('div');
						tip.className = 'article-annotation-tooltip';
						tip.setAttribute('role', 'tooltip');
						var safe = matched.summary.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
						tip.innerHTML = '<span class="article-annotation-label">Resumen ciudadano</span>' + safe;

						var wrap = document.createElement('span');
						wrap.className = 'article-annotation';
						wrap.appendChild(marker);
						wrap.appendChild(tip);
						h.appendChild(wrap);
					});
				})
				.catch(function() { /* silently fail */ });
		}

		var textoTab = document.querySelector('.tab[data-tab="texto"]');
		if (textoTab) {
			textoTab.addEventListener('click', loadAndInject);
			if (textoTab.classList.contains('active')) loadAndInject();
		}
	})();
	</script>

</Base>
