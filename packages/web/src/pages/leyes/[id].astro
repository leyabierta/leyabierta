---
import { getCollection } from "astro:content";
import { promises as fs } from "node:fs";
import MarkdownIt from "markdown-it";
import sanitizeHtml from "sanitize-html";
import Base from "../../layouts/Base.astro";
import { safeJsonLd } from "../../lib/escape";
import { getLaw, getOmnibusDetail, type OmnibusTopic } from "../../lib/api.ts";
import { loadManifest } from "../../lib/manifest.ts";

// Shift all heading levels down by 1 (h1→h2, h2→h3, etc.) so the page
// has a single H1 — the law title rendered in the header above the tabs.
const md = new MarkdownIt();
md.renderer.rules.heading_open = (tokens, idx, options, _env, self) => {
	const token = tokens[idx];
	const origLevel = Number(token.tag.slice(1));
	const level = Math.min(origLevel + 1, 6);
	token.tag = `h${level}`;
	// Add id to headings for linking.
	// Articles get predictable IDs: "articulo-90", "articulo-1-bis"
	// Other headings (titles, chapters, sections) get slugified IDs.
	if (origLevel >= 2) {
		const contentToken = tokens[idx + 1];
		if (contentToken?.content) {
			const text = contentToken.content;
			// Try to extract a predictable article ID first
			const artMatch = text.match(/^Art[ií]culo\s+(\d+(?:\.\d+)?(?:\s*(?:bis|ter|quater|quinquies|sexies|septies))?)/i);
			if (artMatch) {
				const artId = artMatch[1]
					.toLowerCase()
					.replace(/\s+/g, "-")
					.replace(/\./g, "-");
				token.attrSet("id", `articulo-${artId}`);
			} else {
				const slug = text
					.toLowerCase()
					.normalize("NFD").replace(/[\u0300-\u036f]/g, "")
					.replace(/[^a-z0-9]+/g, "-")
					.replace(/^-|-$/g, "")
					.slice(0, 60);
				token.attrSet("id", slug);
			}
		}
	}
	return self.renderToken(tokens, idx, options);
};
md.renderer.rules.heading_close = (tokens, idx, options, _env, self) => {
	const token = tokens[idx];
	const level = Math.min(Number(token.tag.slice(1)) + 1, 6);
	token.tag = `h${level}`;
	return self.renderToken(tokens, idx, options);
};

export async function getStaticPaths() {
	const laws = await getCollection("laws");
	const allIds = new Set(laws.map((e) => e.data.identificador));
	return laws.map((entry) => ({
		params: { id: entry.data.identificador },
		props: { entry, allIds },
	}));
}

const { entry, allIds } = Astro.props;
const { id } = Astro.params;
const law = entry.data;

// Fetch citizen data (summary + tags) + omnibus topics.
// If a build manifest is present (CI), read from local file (zero network calls).
// Otherwise fall back to per-page API calls (local dev).
let citizenSummary = "";
let citizenTags: string[] = [];
let omnibusTopics: OmnibusTopic[] = [];
let omnibusTopicCount = 0;
const manifest = loadManifest();
if (manifest) {
	const citizenData = manifest.citizens[id!];
	citizenSummary = citizenData?.summary ?? "";
	citizenTags = citizenData?.tags ?? [];
	if (law.materias.length >= 15) {
		omnibusTopics = manifest.omnibus[id!] ?? [];
		omnibusTopicCount = omnibusTopics.length;
	}
} else {
	try {
		const detail = await getLaw(id!);
		citizenSummary = detail.citizen_summary ?? "";
		citizenTags = detail.citizen_tags ?? [];
	} catch {
		// API may not be available during build — gracefully degrade
	}
	if (law.materias.length >= 15) {
		try {
			const omnibus = await getOmnibusDetail(id!);
			if (omnibus?.topics?.length) {
				omnibusTopics = omnibus.topics;
				omnibusTopicCount = omnibus.topics.length;
			}
		} catch {
			// Omnibus data not available — skip
		}
	}
}

// Read and render the markdown body on-demand (not during content sync)
let htmlContent = "";
if (entry.body) {
	const raw = await fs.readFile(entry.body, "utf-8");
	const bodyMatch = raw.match(/^---[\s\S]*?---\s*([\s\S]*)$/);
	const body = bodyMatch?.[1] ?? raw;
	htmlContent = sanitizeHtml(md.render(body), {
		allowedTags: [
			"h1", "h2", "h3", "h4", "h5", "h6",
			"p", "ul", "ol", "li", "em", "strong", "a",
			"table", "thead", "tbody", "tr", "th", "td",
			"blockquote", "br", "span", "div", "sup", "sub",
			"hr", "code", "pre", "dl", "dt", "dd",
		],
		allowedAttributes: {
			a: ["href", "title"],
			th: ["colspan", "rowspan"],
			td: ["colspan", "rowspan"],
			span: ["class"],
			div: ["class"],
			h2: ["id"], h3: ["id"], h4: ["id"], h5: ["id"], h6: ["id"],
		},
		allowedSchemes: ["https", "http"],
	});
}

const RANK_LABELS: Record<string, string> = {
	constitucion: "Constitución",
	ley_organica: "Ley Orgánica",
	ley: "Ley",
	real_decreto_ley: "Decreto urgente",
	real_decreto_legislativo: "Decreto legislativo",
	real_decreto: "Real Decreto",
	orden: "Orden",
	decreto: "Decreto",
	circular: "Circular",
	resolucion: "Resolución",
	acuerdo_internacional: "Acuerdo internacional",
	instruccion: "Instrucción",
	reglamento: "Reglamento",
	acuerdo: "Acuerdo",
};

// legislationType accepts free text (schema.org examples: "law", "decree", "loi organique")
const RANK_LEGISLATION_TYPES: Record<string, string> = {
	constitucion: "Constitution",
	ley_organica: "OrganicLaw",
	ley: "Law",
	real_decreto_ley: "RoyalDecreeLaw",
	real_decreto_legislativo: "RoyalLegislativeDecree",
	real_decreto: "RoyalDecree",
	orden: "MinisterialOrder",
	decreto: "Decree",
	circular: "Circular",
	resolucion: "Resolution",
	acuerdo_internacional: "InternationalAgreement",
	instruccion: "Instruction",
	reglamento: "Regulation",
};

const STATUS_LABELS: Record<string, string> = {
	vigente: "En vigor",
	derogada: "Ya no está en vigor",
	parcialmente_derogada: "Parcialmente en vigor",
};

const MONTHS = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
function formatDate(iso: string): string {
	if (!iso) return '';
	const [y, m, d] = iso.split('-');
	return `${parseInt(d!, 10)} de ${MONTHS[parseInt(m!, 10) - 1]} de ${y}`;
}

function capitalize(s: string): string {
	return s ? s.charAt(0).toUpperCase() + s.slice(1) : '';
}

const reforms = (law.reformas ?? []).slice().reverse();
const materias = law.materias ?? [];
const notas = law.notas ?? [];
const refsAnt = law.referencias_anteriores ?? [];
const refsPost = law.referencias_posteriores ?? [];
const articleCount = law.articulos ?? 0;

// ── SEO: generate abbreviation variants (e.g. "RD 769/87") ──
const RANK_ABBREVS: Record<string, string> = {
	real_decreto: "RD", ley_organica: "LO", ley: "L",
	real_decreto_ley: "RDL", real_decreto_legislativo: "RDLeg",
	orden: "O", decreto: "D", resolucion: "Res",
};
const abbrev = RANK_ABBREVS[law.rango] ?? "";
let seoAbbreviations: string[] = [];
if (abbrev) {
	// Extract "769/1987" from title like "Real Decreto 769/1987, de 19 de junio..."
	const numMatch = law.titulo.match(/(\d+\/\d{4})/);
	if (numMatch) {
		const full = numMatch[1]!; // "769/1987"
		const short2 = full.replace(/\/(\d{2})\d{2}$/, "/$1"); // "769/19" — wrong
		const short2digit = full.replace(/\/\d{2}(\d{2})$/, "/$1"); // "769/87"
		seoAbbreviations.push(`${abbrev} ${full}`); // "RD 769/1987"
		if (short2digit !== full) seoAbbreviations.push(`${abbrev} ${short2digit}`); // "RD 769/87"
	}
}
const seoDescription = [
	seoAbbreviations[0],
	citizenSummary || (RANK_LABELS[law.rango] ?? law.rango),
	law.estado === "vigente" ? "En vigor" : law.estado === "derogada" ? "Ya no está en vigor" : "",
	law.departamento,
].filter(Boolean).join(" · ");
---

<Base
	title={seoAbbreviations[0] ? `${seoAbbreviations[0]} — ${law.titulo}` : law.titulo}
	description={seoDescription}
	ogTitle={law.titulo}
	ogType="article"
	ogImage={`${import.meta.env.PUBLIC_API_URL ?? "https://api.leyabierta.es"}/og/${id}`}
	canonicalUrl={`/leyes/${id}/`}
>
	<!-- JSON-LD: Legislation -->
	<script type="application/ld+json" set:html={safeJsonLd({
		"@context": "https://schema.org",
		"@type": "Legislation",
		"name": law.titulo,
		"identifier": law.identificador,
		"description": citizenSummary || law.titulo.slice(0, 160),
		"legislationDate": law.fecha_publicacion,
		"legislationDateVersion": law.ultima_actualizacion,
		"dateModified": law.ultima_actualizacion,
		"legislationJurisdiction": law.jurisdiccion === "es" ? "ES" : law.jurisdiccion.toUpperCase(),
		...(law.estado === "vigente" || law.estado?.startsWith("derogad")
			? { "legislationLegalForce": law.estado === "vigente" ? "InForce" : "NotInForce" }
			: {}),
		...(RANK_LEGISLATION_TYPES[law.rango] ? { "legislationType": RANK_LEGISLATION_TYPES[law.rango] } : {}),
		...(materias.length > 0 ? { "about": materias.map(m => ({ "@type": "Thing", "name": m })) } : {}),
		"inLanguage": "es",
		"url": `https://leyabierta.es/leyes/${id}/`,
		"isPartOf": { "@type": "WebSite", "@id": "https://leyabierta.es/#website" },
		...(seoAbbreviations.length > 0 ? { "alternateName": seoAbbreviations } : {}),
		...(law.fuente ? { "sameAs": law.fuente } : {})
	})} />
	<script type="application/ld+json" set:html={safeJsonLd({
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		"itemListElement": [
			{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://leyabierta.es/" },
			{ "@type": "ListItem", "position": 2, "name": law.titulo, "item": `https://leyabierta.es/leyes/${id}/` }
		]
	})} />
	<style>
		.back-link { font-size: 0.8125rem; color: var(--text-muted); }
		.back-link:hover { color: var(--text-secondary); }

		.law-header {
			display: flex;
			justify-content: space-between;
			align-items: flex-start;
			gap: 1rem;
			margin: 0.75rem 0 0.5rem;
		}
		.law-title {
			font-family: var(--font-serif);
			font-size: 1.375rem;
			font-weight: 700;
			line-height: 1.35;
			letter-spacing: -0.01em;
			flex: 1;
		}
		.boe-btn {
			display: inline-flex;
			align-items: center;
			gap: 0.375rem;
			padding: 0.4rem 0.875rem;
			border: 1.5px solid var(--border);
			border-radius: 6px;
			font-size: 0.8125rem;
			font-weight: 600;
			color: var(--text-secondary);
			background: var(--surface);
			white-space: nowrap;
			flex-shrink: 0;
			transition: all 0.15s;
		}
		.boe-btn:hover { border-color: var(--accent); color: var(--accent); text-decoration: none; }

		.meta-row {
			display: flex;
			flex-wrap: wrap;
			gap: 0.5rem;
			align-items: center;
			font-size: 0.8125rem;
			color: var(--text-muted);
			margin-bottom: 1.5rem;
			line-height: 1.4;
		}
		.meta-sep { color: var(--border); }
		.meta-item { display: inline-flex; align-items: center; gap: 0.3rem; }
		.meta-item svg { flex-shrink: 0; opacity: 0.5; }
		.meta-id { font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted); position: relative; top: 0.5px; }

		/* ── Tabs ── */
		.tabs { display: flex; gap: 0; border-bottom: 1px solid var(--border); }
		.tab {
			padding: 0.5rem 1rem;
			font-size: 0.8125rem;
			font-weight: 500;
			color: var(--text-muted);
			cursor: pointer;
			border: none;
			background: none;
			border-bottom: 2px solid transparent;
			margin-bottom: -1px;
			font-family: var(--font-sans);
		}
		.tab:hover { color: var(--text); }
		.tab.active { color: var(--accent); border-bottom-color: var(--accent); }
		.tab-badge {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			min-width: 1.25rem;
			height: 1.25rem;
			padding: 0 0.3rem;
			border-radius: 100px;
			background: var(--accent-bg);
			color: var(--accent);
			font-size: 0.6875rem;
			font-weight: 600;
			margin-left: 0.375rem;
		}
		.tab-panel { display: none; padding-top: 1.5rem; }
		.tab-panel.active { display: block; }
		.tab-panel-texto.active { display: flex; }

		/* ── Content ── */
		.law-content {
			font-family: var(--font-serif);
			line-height: 1.8;
			font-size: 0.9375rem;
			overflow-wrap: break-word;
			word-break: break-word;
		}
		.law-content :global(h2) { font-size: 1.125rem; font-weight: 700; margin: 2.5rem 0 0.75rem; text-align: center; text-transform: uppercase; letter-spacing: 0.03em; color: var(--text); padding: 0.5rem 0; border-top: 2px solid var(--accent); border-bottom: 1px solid var(--border-light); }
		.law-content :global(h3) { font-size: 1rem; font-weight: 700; color: var(--accent); margin: 2rem 0 0.5rem; font-family: var(--font-sans); text-align: center; text-transform: uppercase; letter-spacing: 0.03em; }
		.law-content :global(h4) { font-size: 0.875rem; font-weight: 600; margin: 1.5rem 0 0.5rem; text-align: center; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.02em; }
		.law-content :global(h5) { font-size: 0.8125rem; font-weight: 600; margin: 1.25rem 0 0.375rem; text-align: center; color: var(--text-muted); font-style: italic; }
		.law-content :global(h6) { font-size: 0.9375rem; font-weight: 700; margin: 1.5rem 0 0.5rem; color: var(--text); padding-bottom: 0.25rem; border-bottom: 1px solid var(--border-light); }
		.law-content :global(p) { margin-bottom: 0.75rem; }
		:global(.law-rubric) { text-align: center; font-weight: 700; color: var(--text); margin-top: -0.25rem; font-family: var(--font-sans); font-size: 0.875rem; }
		/* Offset for scroll-to with sticky header */
		.law-content :global([id]) { scroll-margin-top: 4rem; }
		.law-content :global(hr) { border: none; border-top: 1px solid var(--border-light); margin: 1.5rem 0 0.75rem; }

		/* ── Text tab layout with TOC ── */
		.tab-panel-texto {
			gap: 0;
			align-items: flex-start;
			/* Break out of container to use full viewport width */
			margin-left: calc(-50vw + 50%);
			margin-right: calc(-50vw + 50%);
			padding-left: max(1.25rem, calc(50vw - 36rem));
			padding-right: max(1.25rem, calc(50vw - 36rem));
		}
		.tab-panel-texto .law-content {
			flex: 1;
			min-width: 0;
			max-width: 52rem;
		}
		.toc {
			position: sticky;
			top: 4rem;
			width: 240px;
			flex-shrink: 0;
			max-height: calc(100vh - 5rem);
			overflow-y: auto;
			font-size: 0.8125rem;
			margin-right: 1.5rem;
			padding-right: 1rem;
			border-right: 1px solid var(--border-light);
			scrollbar-width: thin;
			scrollbar-color: var(--border-light) transparent;
		}
		.toc-header {
			font-size: 0.6875rem;
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 0.05em;
			color: var(--text-muted);
			margin-bottom: 0.5rem;
			padding-bottom: 0.375rem;
			border-bottom: 1px solid var(--border-light);
		}
		.toc-list :global(.toc-item) {
			display: block;
			padding: 0.2rem 0.375rem;
			color: var(--text-muted);
			text-decoration: none;
			border-radius: 3px;
			line-height: 1.35;
			margin-bottom: 0.0625rem;
			transition: color 0.1s, background 0.1s;
			overflow: hidden;
			text-overflow: ellipsis;
			white-space: nowrap;
		}
		.toc-list :global(.toc-item:hover) {
			color: var(--accent);
			background: var(--accent-faint);
			text-decoration: none;
		}
		.toc-list :global(.toc-item.toc-active) {
			color: var(--accent);
			font-weight: 600;
			background: var(--accent-bg);
		}
		.toc-list :global(.toc-level-2) { font-weight: 600; color: var(--text); margin-top: 0.625rem; }
		.toc-list :global(.toc-level-3) { padding-left: 0.625rem; margin-top: 0.375rem; font-weight: 600; color: var(--text-secondary); }
		.toc-list :global(.toc-level-4) { padding-left: 1.125rem; }
		.toc-list :global(.toc-level-5) { padding-left: 1.5rem; }
		.toc-list :global(.toc-level-6) { padding-left: 1.875rem; color: var(--text-muted); }

		@media (max-width: 960px) {
			.tab-panel-texto {
				margin-left: 0;
				margin-right: 0;
				padding-left: 0;
				padding-right: 0;
			}
			.toc { display: none; }
		}

		/* ── Resumen components ── */
		/* ── Omnibus notice ── */
		.omnibus-notice {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			padding: 0.625rem 0.875rem;
			background: var(--warning-bg, #fff3cd);
			border-radius: 8px;
			margin-bottom: 1.25rem;
		}
		.omnibus-notice-badge {
			font-size: 0.6875rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.04em;
			color: var(--warning, #856404);
			background: rgba(255,193,7,0.2);
			padding: 0.2rem 0.5rem;
			border-radius: 4px;
			white-space: nowrap;
		}
		.omnibus-notice-text {
			font-size: 0.8125rem;
			color: var(--warning, #856404);
			line-height: 1.4;
		}

		/* ── Omnibus breakdown ── */
		.omnibus-breakdown {
			margin-bottom: 1.5rem;
		}
		.omnibus-topics-list {
			display: flex;
			flex-direction: column;
			gap: 0.75rem;
		}
		.omnibus-topic-card {
			background: var(--surface);
			border: 1px solid var(--border-light);
			border-radius: 10px;
			padding: 1rem 1.25rem;
			width: 100%;
			text-align: left;
			font-family: var(--font-sans);
			cursor: pointer;
			transition: border-color 0.15s, background 0.15s;
		}
		.omnibus-topic-card:hover {
			border-color: var(--accent);
			background: var(--accent-faint);
		}
		.omnibus-topic-action {
			display: block;
			margin-top: 0.5rem;
			font-size: 0.75rem;
			font-weight: 600;
			color: var(--accent);
			opacity: 0;
			transition: opacity 0.15s;
		}
		.omnibus-topic-card:hover .omnibus-topic-action {
			opacity: 1;
		}
		.omnibus-topic-label {
			display: flex;
			gap: 0.5rem;
			align-items: center;
			flex-wrap: wrap;
			margin-bottom: 0.25rem;
		}
		.omnibus-topic-label h3 {
			font-family: var(--font-serif);
			font-size: 1rem;
			font-weight: 600;
			color: var(--text);
			margin: 0;
		}
		.omnibus-topic-articles {
			font-size: 0.75rem;
			color: var(--text-muted);
		}
		.omnibus-topic-headline {
			font-family: var(--font-serif);
			font-size: 0.9375rem;
			font-weight: 600;
			line-height: 1.4;
			margin: 0.25rem 0;
			color: var(--text);
		}
		.omnibus-topic-summary {
			font-size: 0.875rem;
			color: var(--text-secondary);
			line-height: 1.6;
			margin: 0.25rem 0;
		}

		/* ── View toggle ── */
		.view-toggle {
			display: inline-flex;
			align-items: center;
			gap: 0.375rem;
			padding: 0.5rem 0;
			border: none;
			background: none;
			font-size: 0.8125rem;
			font-weight: 500;
			color: var(--accent);
			cursor: pointer;
			font-family: var(--font-sans);
			margin-bottom: 1rem;
		}
		.view-toggle:hover { text-decoration: underline; }
		.technical-details {
			border-top: 1px solid var(--border-light);
			padding-top: 1.25rem;
			margin-top: 0.5rem;
		}

		.quick-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 0.75rem; margin-bottom: 1.5rem; }
		.stat-card { display: flex; align-items: center; gap: 0.625rem; padding: 0.875rem 1rem; background: var(--surface); border: 1px solid var(--border-light); border-radius: 10px; }
		.stat-value { font-variant-numeric: tabular-nums; font-size: 1.25rem; font-weight: 700; color: var(--accent); line-height: 1.2; }
		.stat-label { font-size: 0.6875rem; color: var(--text-muted); }

		.card { background: var(--surface); border: 1px solid var(--border-light); border-radius: 10px; padding: 1.25rem 1.5rem; margin-bottom: 1rem; }
		.card-heading { font-size: 1rem; font-weight: 600; margin-bottom: 0.75rem; }
		.meta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; font-size: 0.875rem; }
		.meta-item-label { color: var(--text-muted); font-size: 0.8125rem; margin-bottom: 0.125rem; }
