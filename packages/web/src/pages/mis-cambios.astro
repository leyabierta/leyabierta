---
import Base from "../layouts/Base.astro";
---

<Base
	title="Mis cambios legislativos"
	description="Los cambios legislativos que afectan a tu situación personal."
	ogTitle="Mis cambios — Ley Abierta"
	canonicalUrl="/mis-cambios"
>
	<style is:global>
		.cambios-wrap {
			max-width: 680px;
			margin: 0 auto;
			padding: 0 1rem 3rem;
		}

		/* ── Header ── */
		.cambios-header {
			margin-bottom: 2rem;
		}
		.cambios-header h1 {
			font-family: var(--font-serif);
			font-size: 2rem;
			font-weight: 700;
			line-height: 1.2;
			color: var(--text);
			margin-bottom: 0.75rem;
		}
		.cambios-meta {
			display: flex;
			flex-wrap: wrap;
			gap: 0.375rem;
			align-items: center;
			margin-bottom: 0.5rem;
		}
		.situation-tag {
			display: inline-block;
			font-size: 0.75rem;
			font-weight: 500;
			padding: 0.2rem 0.625rem;
			border-radius: 6px;
			background: var(--accent-faint);
			color: var(--accent);
		}
		.cambios-info {
			font-size: 0.8125rem;
			color: var(--text-muted);
			display: flex;
			gap: 0.5rem;
			align-items: center;
			flex-wrap: wrap;
		}
		.cambios-info a {
			color: var(--accent);
		}

		/* ── Loading skeleton ── */
		.skeleton-cards {
			display: flex;
			flex-direction: column;
			gap: 1rem;
		}
		.skeleton-card {
			background: var(--surface);
			border: 1px solid var(--border-light);
			border-radius: 12px;
			padding: 1.25rem;
		}
		.skeleton-line {
			height: 0.875rem;
			background: var(--border-light);
			border-radius: 4px;
			margin-bottom: 0.625rem;
			animation: pulse 1.5s ease-in-out infinite;
		}
		.skeleton-line:nth-child(2) { width: 75%; }
		.skeleton-line:nth-child(3) { width: 60%; }
		@keyframes pulse {
			0%, 100% { opacity: 0.4; }
			50% { opacity: 1; }
		}

		/* ── Empty state ── */
		.empty-state {
			text-align: center;
			padding: 3rem 1.5rem;
			background: var(--surface);
			border: 1px solid var(--border-light);
			border-radius: 12px;
		}
		.empty-check {
			width: 56px;
			height: 56px;
			border-radius: 50%;
			background: var(--success-bg);
			color: var(--success);
			display: inline-flex;
			align-items: center;
			justify-content: center;
			font-size: 1.5rem;
			margin-bottom: 1rem;
		}
		.empty-state h2 {
			font-family: var(--font-serif);
			font-size: 1.375rem;
			font-weight: 700;
			margin-bottom: 0.5rem;
		}
		.empty-state p {
			color: var(--text-secondary);
			font-size: 0.9375rem;
			max-width: 24rem;
			margin: 0 auto;
			line-height: 1.6;
		}

		/* ── Error state ── */
		.error-state {
			text-align: center;
			padding: 2rem 1.5rem;
			background: var(--danger-bg);
			border: 1px solid var(--danger);
			border-radius: 12px;
		}
		.error-state p {
			color: var(--danger);
			font-size: 0.9375rem;
			margin-bottom: 1rem;
		}
		.btn-retry {
			background: var(--danger);
			color: white;
			border: none;
			border-radius: 8px;
			padding: 0.625rem 1.25rem;
			font-size: 0.875rem;
			font-weight: 600;
			font-family: var(--font-sans);
			cursor: pointer;
			min-height: 48px;
		}
		.btn-retry:hover {
			opacity: 0.9;
		}

		/* ── Reform cards ── */
		.reform-timeline {
			display: flex;
			flex-direction: column;
			gap: 1rem;
		}
		.reform-card {
			background: var(--surface);
			border: 1px solid var(--border-light);
			border-radius: 12px;
			padding: 1.25rem;
			transition: box-shadow 0.2s;
		}
		.reform-card:hover {
			box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
		}
		.reform-card-high {
			border-left: 3px solid var(--accent);
		}
		.reform-card-compact {
			padding: 0.75rem 1.25rem;
		}
		.reform-date-row {
			display: flex;
			gap: 0.5rem;
			align-items: center;
			margin-bottom: 0.25rem;
		}
		.reform-date {
			font-size: 0.75rem;
			color: var(--text-muted);
			font-family: var(--font-mono);
		}
		.reform-type-badge {
			font-size: 0.6875rem;
			font-weight: 500;
			color: var(--text-muted);
		}
		.reform-importance-badge {
			font-size: 0.6875rem;
			font-weight: 600;
			color: var(--accent);
			background: var(--accent-faint);
			padding: 0.125rem 0.5rem;
			border-radius: 4px;
		}
		.reform-headline {
			font-family: var(--font-serif);
			font-size: 1.0625rem;
			font-weight: 600;
			line-height: 1.4;
			margin: 0.375rem 0 0.25rem;
			color: var(--text);
		}
		.reform-summary {
			font-size: 0.9rem;
			color: var(--text-secondary);
			line-height: 1.6;
			margin-bottom: 0.5rem;
		}
		.reform-title-fallback {
			font-family: var(--font-serif);
			font-size: 1.0625rem;
			font-weight: 600;
			line-height: 1.4;
			margin: 0.375rem 0 0.5rem;
			color: var(--text);
		}
		.reform-meta {
			display: flex;
			gap: 0.5rem;
			align-items: center;
			flex-wrap: wrap;
			margin-bottom: 0.5rem;
			font-size: 0.8125rem;
			color: var(--text-muted);
		}
		.reform-link {
			font-size: 0.8125rem;
			color: var(--accent-light);
			font-weight: 500;
		}
		.reform-link:hover {
			text-decoration: underline;
		}

		/* ── Email CTA ── */
		.email-cta {
			margin-top: 2.5rem;
			padding: 2rem;
			background: var(--accent-faint);
			border: 1px solid var(--border-light);
			border-radius: 12px;
			text-align: center;
		}
		.email-cta h2 {
			font-family: var(--font-serif);
			font-size: 1.25rem;
			font-weight: 700;
			margin-bottom: 0.375rem;
		}
		.email-cta > p {
			color: var(--text-secondary);
			font-size: 0.9rem;
			margin-bottom: 1.25rem;
		}
		.email-cta form {
			max-width: 24rem;
			margin: 0 auto;
			text-align: left;
		}
		.email-cta input[type="email"] {
			width: 100%;
			padding: 0.75rem;
			border: 1px solid var(--border);
			border-radius: 8px;
			background: var(--surface);
			color: var(--text);
			font-size: 0.9375rem;
			font-family: var(--font-sans);
			margin-bottom: 0.75rem;
		}
		.email-cta input[type="email"]:focus {
			outline: none;
			border-color: var(--accent);
			box-shadow: 0 0 0 2px var(--accent-bg);
		}
		.consent-row {
			display: flex;
			align-items: flex-start;
			gap: 0.5rem;
			margin-bottom: 1rem;
		}
		.consent-row input[type="checkbox"] {
			margin-top: 0.2rem;
			flex-shrink: 0;
			accent-color: var(--accent);
		}
		.consent-row label {
			font-size: 0.8125rem;
			color: var(--text-secondary);
			line-height: 1.5;
		}
		.consent-row a {
			color: var(--accent);
			text-decoration: underline;
		}
		.email-cta .btn-primary {
			width: 100%;
			justify-content: center;
			min-height: 48px;
		}
		.email-cta .btn-primary:disabled {
			opacity: 0.5;
			cursor: not-allowed;
		}
		.email-success {
			display: none;
			color: var(--success);
			font-size: 0.875rem;
			font-weight: 500;
			margin-top: 0.75rem;
		}
		.email-error {
			display: none;
			color: var(--danger);
			font-size: 0.875rem;
			margin-top: 0.75rem;
		}
		.email-hint {
			font-size: 0.8125rem;
			color: var(--text-tertiary, var(--text-secondary));
			margin-top: 0.375rem;
			text-align: center;
			transition: opacity 0.2s;
		}

		/* ── Responsive ── */
		@media (max-width: 640px) {
			.cambios-header h1 { font-size: 1.625rem; }
			.cambios-wrap { padding-bottom: 2rem; }
		}
	</style>

	<div class="cambios-wrap">
		<div class="cambios-header">
			<h1>Tus cambios legislativos</h1>
			<div class="cambios-meta" id="cambios-meta"></div>
			<div class="cambios-info" id="cambios-info"></div>
		</div>

		<section class="email-cta" id="email-cta" style="display:none">
			<h2>¿Quieres recibir avisos por email?</h2>
			<p>Te avisamos cuando cambien leyes que te afectan. Sin spam, solo lo relevante.</p>
			<form id="email-form">
				<input type="email" placeholder="tu@email.com" required autocomplete="email" id="email-input" />
				<div class="consent-row">
					<input type="checkbox" id="email-consent" />
					<label for="email-consent">He leído la <a href="/privacidad">política de privacidad</a></label>
				</div>
				<button type="submit" class="btn btn-primary" id="email-submit" disabled>Suscribirme</button>
				<p class="email-hint" id="email-hint">Marca la casilla de privacidad para continuar</p>
			</form>
			<div class="email-success" id="email-success">¡Listo! Revisa tu email para confirmar.</div>
			<div class="email-error" id="email-error"></div>
		</section>

		<div id="cambios-content">
			<div class="skeleton-cards">
				<div class="skeleton-card"><div class="skeleton-line" style="width:40%"></div><div class="skeleton-line" style="width:90%"></div><div class="skeleton-line"></div><div class="skeleton-line" style="width:60%"></div></div>
				<div class="skeleton-card"><div class="skeleton-line" style="width:35%"></div><div class="skeleton-line" style="width:85%"></div><div class="skeleton-line"></div><div class="skeleton-line" style="width:55%"></div></div>
				<div class="skeleton-card"><div class="skeleton-line" style="width:45%"></div><div class="skeleton-line" style="width:80%"></div><div class="skeleton-line"></div><div class="skeleton-line" style="width:50%"></div></div>
			</div>
		</div>
	</div>

	<script is:inline>
		(function () {
			var ANSWER_LABELS = {
				cuenta_ajena: "Empleado/a",
				autonomo: "Autónomo/a",
				empresa: "Empresario/a",
				jubilado: "Jubilado/a",
				busco_empleo: "Busco empleo",
				estudiante: "Estudiante",
				no_trabajo: "No trabajo",
				sanidad: "Sanidad",
				educacion: "Educación",
				admin_publica: "Admin. pública",
				campo: "Campo/pesca/ganadería",
				construccion: "Construcción",
				hosteleria: "Hostelería",
				transporte: "Transporte",
				tecnologia: "Tecnología",
				otro: "Otro sector",
				alquilo: "Alquiler",
				hipoteca: "Hipoteca",
				propietario: "Propietario/a",
				familiares: "Vivo con familiares",
				hijos_menores: "Hijos menores",
				dependiente: "Familiar dependiente",
				embarazo_baja: "Embarazo/baja",
				coche: "Conduzco",
				inversiones: "Inversiones",
				mascotas: "Mascotas",
				casero: "Casero/a",
				divorcio: "Divorcio",
				discapacidad: "Discapacidad",
				extranjeria: "Extranjería",
				ecommerce: "E-commerce",
				herencia: "Herencia",
				medioambiente: "Medio ambiente",
				deporte: "Deporte"
			};

			var JURISDICTION_NAMES = {
				es: "Estatal", "es-an": "Andalucía", "es-ar": "Aragón", "es-as": "Asturias",
				"es-cb": "Cantabria", "es-cl": "Castilla y León", "es-cm": "Castilla-La Mancha",
				"es-cn": "Canarias", "es-ct": "Cataluña", "es-ex": "Extremadura", "es-ga": "Galicia",
				"es-ib": "Illes Balears", "es-mc": "Murcia", "es-md": "Madrid", "es-nc": "Navarra",
				"es-pv": "País Vasco", "es-ri": "La Rioja", "es-vc": "C. Valenciana"
			};

			var RANK_LABELS = {
				constitucion: "Constitución", ley_organica: "Ley Orgánica", ley: "Ley",
				real_decreto_ley: "Real Decreto-ley", real_decreto_legislativo: "RD Legislativo",
				real_decreto: "Real Decreto", orden: "Orden", resolucion: "Resolución",
				acuerdo_internacional: "Acuerdo Int.", circular: "Circular",
				instruccion: "Instrucción", decreto: "Decreto", reglamento: "Reglamento"
			};

			function esc(s) { return String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;"); }

			var API = document.documentElement.dataset.api;
			var contentDiv = document.getElementById("cambios-content");
			var metaDiv = document.getElementById("cambios-meta");
			var infoDiv = document.getElementById("cambios-info");
			var emailCta = document.getElementById("email-cta");

			// Read localStorage
			var perfil = null;
			try {
				perfil = JSON.parse(localStorage.getItem("leyabierta_perfil") || "null");
			} catch (e) {}

			if (!perfil || !perfil.materias || perfil.materias.length === 0) {
				window.location.href = "/mi-situacion";
				return;
			}

			var materias = perfil.materias;
			var jurisdiccion = perfil.jurisdiccion || "es";
			var answersObj = perfil.answers || {};

			// Render header tags
			var pillsHtml = "";
			var tagKeys = [];
			if (answersObj.workStatus) tagKeys.push(answersObj.workStatus);
			if (answersObj.sector) tagKeys.push(answersObj.sector);
			if (answersObj.housing) tagKeys.push(answersObj.housing);
			if (answersObj.family) {
				for (var fi = 0; fi < answersObj.family.length; fi++) tagKeys.push(answersObj.family[fi]);
			}
			if (answersObj.extras) {
				for (var ei = 0; ei < answersObj.extras.length; ei++) tagKeys.push(answersObj.extras[ei]);
			}
			for (var t = 0; t < tagKeys.length; t++) {
				var label = ANSWER_LABELS[tagKeys[t]] || tagKeys[t];
				pillsHtml += '<span class="situation-tag">' + esc(label) + '</span>';
			}
			metaDiv.innerHTML = pillsHtml;
			infoDiv.innerHTML = esc(JURISDICTION_NAMES[jurisdiccion] || jurisdiccion) + ' · Últimas 4 semanas · <a href="/mi-situacion">Cambiar situación</a>';

			// Fetch data
			function loadData() {
				contentDiv.innerHTML = '<div class="skeleton-cards"><div class="skeleton-card"><div class="skeleton-line" style="width:40%"></div><div class="skeleton-line" style="width:90%"></div><div class="skeleton-line"></div><div class="skeleton-line" style="width:60%"></div></div><div class="skeleton-card"><div class="skeleton-line" style="width:35%"></div><div class="skeleton-line" style="width:85%"></div><div class="skeleton-line"></div><div class="skeleton-line" style="width:55%"></div></div><div class="skeleton-card"><div class="skeleton-line" style="width:45%"></div><div class="skeleton-line" style="width:80%"></div><div class="skeleton-line"></div><div class="skeleton-line" style="width:50%"></div></div></div>';

				var controller = new AbortController();
				var timeout = setTimeout(function () { controller.abort(); }, 10000);

				fetch(API + "/v1/reforms/personal?materias=" + encodeURIComponent(materias.join(",")) + "&jurisdiccion=" + jurisdiccion + "&weeks=4", { signal: controller.signal })
					.then(function (r) { return r.json(); })
					.then(function (data) {
						clearTimeout(timeout);
						if (!data.reforms || data.reforms.length === 0) {
							contentDiv.innerHTML = '<div class="empty-state"><div class="empty-check">&#10003;</div><h2>No hay cambios recientes que te afecten</h2><p>¡Buenas noticias! Te avisaremos cuando algo cambie.</p></div>';
							emailCta.style.display = "";
							return;
						}

						var TYPE_LABELS = {
							new_law: "Ley nueva",
							modification: "Modificación",
							correction: "Corrección",
							derogation: "Derogación"
						};

						var html = '<div class="reform-timeline">';
						for (var i = 0; i < data.reforms.length; i++) {
							var r = data.reforms[i];
							var dateStr = r.date || "";
							if (dateStr) {
								var d = new Date(dateStr + "T00:00:00");
								var months = ["ene", "feb", "mar", "abr", "may", "jun", "jul", "ago", "sep", "oct", "nov", "dic"];
								dateStr = d.getDate() + " " + months[d.getMonth()] + " " + d.getFullYear();
							}
							var statusLabel = r.status || "";
							var statusClass = "badge badge-" + (r.status || "vigente");
							var rankLabel = RANK_LABELS[r.rank] || r.rank || "";
							var hasHeadline = r.headline && r.headline.length > 0;
							var importance = r.importance || "";
							var reformType = r.reform_type || "";
							var typeLabel = TYPE_LABELS[reformType] || "";

							// Compact card for low importance
							if (importance === "low" && hasHeadline) {
								html += '<div class="reform-card reform-card-compact">';
								html += '<span class="reform-date">' + esc(dateStr) + '</span>';
								html += ' · <span class="reform-type-badge">' + esc(r.headline) + '</span>';
								html += ' · <a href="/reforma?id=' + encodeURIComponent(r.id) + '&date=' + encodeURIComponent(r.date) + '&from=mis-cambios" class="reform-link">Ver →</a>';
								html += '</div>';
								continue;
							}

							var cardClass = "reform-card";
							if (importance === "high") cardClass += " reform-card-high";

							html += '<div class="' + cardClass + '">';
							html += '<div class="reform-date-row">';
							html += '<span class="reform-date">' + esc(dateStr) + '</span>';
							if (typeLabel) html += '<span class="reform-type-badge"> · ' + esc(typeLabel) + '</span>';
							if (importance === "high") html += '<span class="reform-importance-badge">Cambio importante</span>';
							// Omnibus badge only for new laws, not modifications to existing omnibus laws
							var isNewLaw = reformType === "new_law";
							if (isNewLaw) {
								var otc = r.omnibus_topic_count || 0;
								var mc = r.materia_count || 0;
								if (otc > 0) {
									html += '<a href="/omnibus/detalle?id=' + encodeURIComponent(r.id) + '" class="reform-importance-badge" style="background:var(--warning-bg,#fff3cd);color:var(--warning,#856404);text-decoration:none;">LEY ÓMNIBUS (' + otc + ' temas)</a>';
								} else if (mc >= 15) {
									html += '<span class="reform-importance-badge" style="background:var(--warning-bg,#fff3cd);color:var(--warning,#856404);">LEY ÓMNIBUS (' + mc + ' materias)</span>';
								}
							}
							html += '</div>';

							if (hasHeadline) {
								html += '<h3 class="reform-headline">' + esc(r.headline) + '</h3>';
								if (r.summary) html += '<p class="reform-summary">' + esc(r.summary) + '</p>';
							} else {
								html += '<h3 class="reform-title-fallback">' + esc(r.title) + '</h3>';
							}

							// "Te afecta por" — show matched omnibus topics (only for new omnibus laws)
							if (isNewLaw) {
								var mt = r.matched_topics || [];
								if (mt.length > 0) {
									var topicText = esc(mt[0]);
									if (mt.length > 1) topicText += ' (+' + (mt.length - 1) + ' más)';
									html += '<div class="reform-affects" style="font-size:0.8125rem;color:var(--accent);margin:0.375rem 0;">Te afecta por: ' + topicText + '</div>';
								}
							}

							html += '<div class="reform-meta">';
							if (rankLabel) html += '<span>' + esc(rankLabel) + '</span>';
							if (statusLabel) html += '<span class="' + statusClass + '">' + esc(statusLabel) + '</span>';
							html += '</div>';
							html += '<a href="/reforma?id=' + encodeURIComponent(r.id) + '&date=' + encodeURIComponent(r.date) + '&from=mis-cambios" class="reform-link">Ver qué cambió →</a>';
							html += '</div>';
						}
						html += '</div>';
						contentDiv.innerHTML = html;
						emailCta.style.display = "";
					})
					.catch(function () {
						clearTimeout(timeout);
						contentDiv.innerHTML = '<div class="error-state" role="alert"><p>Error al cargar. Inténtalo de nuevo.</p><button type="button" class="btn-retry" id="btn-retry">Reintentar</button></div>';
						var retryBtn = document.getElementById("btn-retry");
						if (retryBtn) {
							retryBtn.addEventListener("click", loadData);
						}
					});
			}

			loadData();

			// Email CTA form
			var emailInput = document.getElementById("email-input");
			var emailConsent = document.getElementById("email-consent");
			var emailSubmit = document.getElementById("email-submit");
			var emailSuccess = document.getElementById("email-success");
			var emailError = document.getElementById("email-error");
			var emailForm = document.getElementById("email-form");

			var emailHint = document.getElementById("email-hint");
			function validateEmail() {
				var valid = emailInput.value && emailInput.validity.valid && emailConsent.checked;
				emailSubmit.disabled = !valid;
				if (emailHint) emailHint.style.display = valid ? "none" : "";
			}
			emailInput.addEventListener("input", validateEmail);
			emailConsent.addEventListener("change", validateEmail);

			emailForm.addEventListener("submit", function (e) {
				e.preventDefault();
				emailSubmit.disabled = true;
				emailSubmit.textContent = "Enviando...";
				emailError.style.display = "none";

				fetch(API + "/v1/alerts/subscribe", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify({
						email: emailInput.value,
						materias: materias,
						jurisdiction: jurisdiccion
					})
				})
				.then(function (r) { return r.json(); })
				.then(function (data) {
					if (data.ok) {
						emailForm.style.display = "none";
						emailSuccess.style.display = "block";
					} else {
						emailSubmit.disabled = false;
						emailSubmit.textContent = "Suscribirme";
						emailError.textContent = data.error || "Ha ocurrido un error. Inténtalo de nuevo.";
						emailError.style.display = "block";
					}
				})
				.catch(function () {
					emailSubmit.disabled = false;
					emailSubmit.textContent = "Suscribirme";
					emailError.textContent = "Error de conexión. Inténtalo de nuevo.";
					emailError.style.display = "block";
				});
			});
		})();
	</script>
</Base>
