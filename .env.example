# === Required in production ===

# HMAC secret for email confirmation tokens (generate: openssl rand -hex 32)
ALERTS_SECRET=

# Resend email service (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_AUDIENCE_ID=

# === Optional (have defaults) ===

# Database path (default: ./data/leyabierta.db)
DB_PATH=./data/leyabierta.db

# Path to leyes repository (default: ../leyes)
REPO_PATH=../leyes

# Server port (default: 3000)
PORT=3000

# Public site URL (default: https://leyabierta.es)
SITE_URL=https://leyabierta.es

# From email (default: Ley Abierta <alertas@leyabierta.es>)
FROM_EMAIL=Ley Abierta <alertas@leyabierta.es>

# CORS origins, comma-separated (default: leyabierta.es + localhost)
CORS_ORIGINS=https://leyabierta.es,https://www.leyabierta.es,http://localhost:4321

# Environment (default: development)
NODE_ENV=development

# === AI summaries (OpenRouter) ===

OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxx

# === RAG NaN stack (Phase 5 — Qwen3 via api.nan.builders) ===

# Set NAN_STACK=true to use the full NaN stack for RAG:
#   - Embeddings: qwen3-embedding (4096 dims) via NaN
#   - Query analyzer LLM: qwen3.6 via NaN (replaces gemini-2.5-flash-lite)
#   - Reranker: qwen3.6 LLM rerank via NaN (replaces cohere/rerank-4-pro)
# A/B Phase 5 result on 50 citizen queries × 9.7k norms: +30 pp R@1 vs Gemini.
# Cost: zero. Requires HERMES_API_KEY to be set.
NAN_STACK=false

# NaN API key (https://nan.builders). Used when NAN_STACK=true.
HERMES_API_KEY=

# Override the low-confidence early-return threshold for Qwen embeddings.
# Default 0.55 (Qwen produces higher cosines than Gemini's 0.38).
# LOW_CONFIDENCE_THRESHOLD_QWEN=0.55
