# === Required in production ===

# HMAC secret for email confirmation tokens (generate: openssl rand -hex 32)
ALERTS_SECRET=

# Resend email service (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_AUDIENCE_ID=

# === Optional (have defaults) ===

# Database path (default: ./data/leyabierta.db)
DB_PATH=./data/leyabierta.db

# Path to leyes repository (default: ../leyes)
REPO_PATH=../leyes

# Server port (default: 3000)
PORT=3000

# Public site URL (default: https://leyabierta.es)
SITE_URL=https://leyabierta.es

# From email (default: Ley Abierta <alertas@leyabierta.es>)
FROM_EMAIL=Ley Abierta <alertas@leyabierta.es>

# CORS origins, comma-separated (default: leyabierta.es + localhost)
CORS_ORIGINS=https://leyabierta.es,https://www.leyabierta.es,http://localhost:4321

# Environment (default: development)
NODE_ENV=development

# === AI summaries (OpenRouter) ===

OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxx

# === RAG NaN stack (Phase 5/6 — qwen3 via api.nan.builders, prod default) ===
#
# Required. Used by:
#   - Embeddings: qwen3-embedding (4096 dims), the prod default
#   - Query analyzer: qwen3.6 (replaces gemini-2.5-flash-lite, +4 pp R@1)
#   - Reranker: qwen3.6 LLM rerank (replaces cohere/rerank-4-pro, +18 pp R@1)
#   - Synthesis: qwen3.6 (replaces gemini-2.5-flash-lite, judge 8.82 vs 7.17)
#
# Combined Phase 5+6 A/B result on 50 citizen queries × 9.7k norms:
#   +30 pp R@1 retrieval, +1.65 pts overall synthesis quality, $0 cost.
HERMES_API_KEY=

# Optional override: low-confidence early-return threshold for retrieval.
# Default 0.40 (effectively off — bestScore is not informative about
# correctness with the qwen+qwen+qwen stack; calibration in Phase 5 showed
# hit/miss distributions overlap, separation ~0.04). Used only to catch
# catastrophic embedding failures.
# LOW_CONFIDENCE_THRESHOLD=0.40
